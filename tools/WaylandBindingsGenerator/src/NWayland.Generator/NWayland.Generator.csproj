<Project Sdk="Microsoft.NET.Sdk">

	<!-- Frozen, CodeBrix-owned fork of the NWayland bindings generator (MIT) — dev-only tool.
	     NOT packed into any NuGet; run via ../GeneratorRunner. See ../../PORTING-NOTES.txt for
	     the upstream commit SHA, the license, and the list of fork patches. -->
	<PropertyGroup>
		<TargetFramework>netstandard2.0</TargetFramework>
		<Nullable>enable</Nullable>
		<LangVersion>latest</LangVersion>
		<RootNamespace>NWayland.Generator</RootNamespace>
		<IsPackable>false</IsPackable>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="4.3.0" />
	</ItemGroup>

</Project>
