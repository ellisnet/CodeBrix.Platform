<Project Sdk="Microsoft.NET.Sdk">

	<!-- Dev-only console runner: feeds the pinned protocol XML through the frozen generator
	     fork and writes the committed bindings into the Wayland head's Wayland_Bindings/ folder.
	     Usage (from the repo root):
	         dotnet run [dash][dash]project tools/WaylandBindingsGenerator/src/GeneratorRunner
	     (see README.md for the copy-pasteable command) -->
	<PropertyGroup>
		<OutputType>Exe</OutputType>
		<TargetFramework>net10.0</TargetFramework>
		<Nullable>enable</Nullable>
		<ImplicitUsings>enable</ImplicitUsings>
		<IsPackable>false</IsPackable>
	</PropertyGroup>

	<ItemGroup>
		<ProjectReference Include="..\NWayland.Generator\NWayland.Generator.csproj" />
	</ItemGroup>

</Project>
