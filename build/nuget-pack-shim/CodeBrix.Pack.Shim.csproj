<Project Sdk="Microsoft.NET.Sdk">

	<!--
	========================================================================
	CodeBrix.Platform pack shim
	========================================================================
	A throwaway SDK project that exists only so the modern .NET SDK packer
	(which understands net10.0) can pack a standalone .nuspec. The bundled
	build\external\nuget\NuGet.exe is 5.4.0 (2019) and mis-emits net10.0
	dependency groups as ".NETFramework10.0", so it cannot be used.

	The driver (CodeBrix.Platform.Build.csproj) invokes this shim once per
	nuspec via `dotnet pack`, passing these as -p: properties:

	  CbxNuspec          absolute path to the .nuspec to pack
	  CbxNuspecBasePath   base dir the nuspec's <file src> paths resolve against
	  CbxVersion          the shared date-stamped version ($codebrixversion$)
	  CbxBranch / CbxCommit  git info for the <repository> tokens
	  PackageOutputPath   where the .nupkg is written  (passed as -o)

	The package's own <version> comes from the nuspec (literal, or the
	$codebrixversion$ token for date-stamped packages — that is how the
	SkiaSharp.Views pin is preserved: it uses a literal version, not the token).
	========================================================================
	-->

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<!-- This project ships no code; it only drives a nuspec pack. -->
		<IncludeBuildOutput>false</IncludeBuildOutput>
		<EnableDefaultCompileItems>false</EnableDefaultCompileItems>
		<GenerateAssemblyInfo>false</GenerateAssemblyInfo>
		<NoWarn>$(NoWarn);NU5128;CS2008</NoWarn>
		<IsPackable>true</IsPackable>

		<NuspecFile>$(CbxNuspec)</NuspecFile>
		<NuspecBasePath>$(CbxNuspecBasePath)</NuspecBasePath>
		<NuspecProperties>codebrixversion=$(CbxVersion);branch=$(CbxBranch);commitid=$(CbxCommit)</NuspecProperties>
	</PropertyGroup>

</Project>
