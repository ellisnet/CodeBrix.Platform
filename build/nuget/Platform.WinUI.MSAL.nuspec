<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2010/07/nuspec.xsd">
	<metadata minClientVersion="5.0">
		<id>CodeBrix.Platform.WinUI.MSAL</id>
		<version>0.0.1</version>
		<authors>Uno Platform</authors>
		<icon>icon-codebrix-128.png</icon>
		<projectUrl>https://github.com/unoplatform/uno</projectUrl>
		<license type="expression">Apache-2.0</license>
		<description>This package provides the extensions to MSAL (Microsoft.Identity.Client) for an Uno Platform application.</description>
		<copyright>Copyright (c) 2026 Jeremy Ellis and contributors</copyright>
		<repository type="git" url="https://github.com/unoplatform/uno.git" branch="$branch$" commit="$commitid$" />
		<dependencies>
			<group targetFramework="net10.0">
				<dependency id="CodeBrix.Platform.WinUI" version="to-be-set-by-ci" />
				<dependency id="Microsoft.Identity.Client" version="4.72.1" />
			</group>

			<!-- BEGIN UWP-specific
			<group targetFramework="UAP10.0.19041">
				<dependency id="Microsoft.Identity.Client" version="4.72.1" />
			</group>
			END UWP-specific -->

			<!-- BEGIN WinUI-specific -->
			<group targetFramework="net10.0-windows10.0.19041.0">
				<dependency id="Microsoft.Identity.Client" version="4.72.1" />
			</group>
			<!-- END WinUI-specific -->

		</dependencies>
	</metadata>

	<files>
		<file src="..\..\icon-codebrix-128.png" target="/" />
		<file src="..\..\README.md" target="/" />
		<file src="..\..\AGENT-README.txt" target="/" />
		<file src="..\..\THIRD-PARTY-NOTICES.txt" target="/" />

		<file src="..\..\src\AddIns\Platform.UI.MSAL\bin\Platform.UI.MSAL.Reference\Release\net10.0\Uno.UI.MSAL.*" target="lib\net10.0" />

		<!-- BEGIN UWP-specific
		<file src="..\..\src\AddIns\Platform.UI.MSAL\bin\Platform.UI.MSAL.Windows\Release\uap10.0.19041\Uno.UI.MSAL.*" target="lib\uap10.0.19041" />
		END UWP-specific -->

		<!-- BEGIN WinUI-specific -->
		<!-- END WinUI-specific -->

		<!-- Build targets -->
		<file src="..\..\src\AddIns\Platform.UI.MSAL\buildTransitive\*" target="buildTransitive" />

		<!-- net10.0 Skia -->
		<file src="..\..\src\AddIns\Platform.UI.MSAL\Bin\Platform.UI.MSAL.Skia\Release\net10.0\Uno.UI.MSAL.*" target="codebrix-platform-runtime\net10.0\skia" />

	</files>

</package>
