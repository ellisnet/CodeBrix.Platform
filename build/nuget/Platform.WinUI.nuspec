		<!-- Analyzers + Roslyn source generators                         -->
		<!-- ============================================================ -->
		<file src="..\..\src\Platform.Analyzers\Bin\Release\CodeBrix.Platform.Analyzers.dll" target="analyzers/dotnet/cs" />
		<file src="..\..\src\Platform.Analyzers\Bin\Release\CodeBrix.Platform.Analyzers.pdb" target="analyzers/dotnet/cs" />

		<file src="..\..\src\SourceGenerators\Platform.UI.SourceGenerators\Bin\Release\netstandard2.0\CodeBrix.Platform.UI.SourceGenerators.dll" target="analyzers/dotnet/cs" />
		<file src="..\..\src\SourceGenerators\Platform.UI.SourceGenerators\Bin\Release\netstandard2.0\CodeBrix.Platform.UI.SourceGenerators.pdb" target="analyzers/dotnet/cs" />
		<file src="..\..\src\SourceGenerators\Platform.UI.SourceGenerators\Bin\Release\netstandard2.0\CodeBrix.Platform.Xaml.dll" target="analyzers/dotnet/cs" />
		<file src="..\..\src\SourceGenerators\Platform.UI.SourceGenerators\Bin\Release\netstandard2.0\CodeBrix.Platform.Xaml.pdb" target="analyzers/dotnet/cs" />
		<!-- Telemetry DLLs (Microsoft.ApplicationInsights, DevTools.Telemetry,
		     DiagnosticSource, DotNet.PlatformAbstractions) were dropped in this fork,
		     so they are not packed. -->


		<!-- Build-time MSBuild tasks. Folder name must match what Platform.UI.Tasks.targets
		     resolves the task assembly from ($(MSBuildThisFileDirectory)CodeBrix.Platform.UI.Tasks\). -->
		<file src="..\..\src\SourceGenerators\Platform.UI.Tasks\Bin\Release\*.dll" target="buildTransitive\CodeBrix.Platform.UI.Tasks" />
		<file src="..\..\src\SourceGenerators\Platform.UI.Tasks\Bin\Release\*.pdb" target="buildTransitive\CodeBrix.Platform.UI.Tasks" />

		<!-- Without tools directory, NuGet's RestoreTask won't generate the package-folder property. -->
		<file src="_._" target="tools" />

		<!-- ============================================================ -->
		<!-- buildTransitive MSBuild logic (cross-runtime / Skia)         -->
		<!-- ============================================================ -->
		<!-- Auto-import entry files: NuGet imports buildTransitive\<PackageId>.props|targets.
		     These are platform.winui.props/targets renamed to the package id; they import
		     the sibling logic below via $(MSBuildThisFileDirectory). -->
		<file src="platform.winui.props" target="buildTransitive\CodeBrix.Platform.ApacheLicenseForever.props" />
		<file src="platform.winui.targets" target="buildTransitive\CodeBrix.Platform.ApacheLicenseForever.targets" />

		<file src="platform.winui.cross-runtime.targets" target="buildTransitive" />
		<file src="platform.winui.common.targets" target="buildTransitive" />
		<file src="platform.winui.common.props" target="buildTransitive" />
		<file src="platform.winui.single-project.targets" target="buildTransitive" />
		<file src="platform.winui.runtime-replace.targets" target="buildTransitive" />
		<file src="platform.winui.winappsdk.targets" target="buildTransitive" />
		<file src="..\..\src\SourceGenerators\Platform.UI.Tasks\Content\**" target="buildTransitive" />

		<file src="..\..\src\SourceGenerators\Platform.UI.SourceGenerators\Content\Platform.UI.SourceGenerators.props" target="buildTransitive" />
	</files>
</package>
