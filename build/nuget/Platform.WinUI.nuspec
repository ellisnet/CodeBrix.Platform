		<!-- Folded-in: Foundation, WinRT (Platform), Dispatching, Foundation.Logging (skia) -->
		<file src="..\..\src\Platform.Foundation\bin\Platform.Foundation.Skia\Release\net10.0\CodeBrix.Platform.Foundation.dll" target="codebrix-platform-runtime\net10.0\skia" />
