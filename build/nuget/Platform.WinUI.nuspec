<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2010/07/nuspec.xsd">
	<metadata minClientVersion="5.0">
		<id>CodeBrix.Platform.ApacheLicenseForever</id>
		<version>$codebrixversion$</version>
		<title>CodeBrix.Platform</title>
		<authors>Jeremy Ellis and contributors</authors>
		<requireLicenseAcceptance>true</requireLicenseAcceptance>
		<projectUrl>https://github.com/ellisnet/CodeBrix.Platform</projectUrl>
		<license type="expression">Apache-2.0</license>
		<icon>icon-codebrix-128.png</icon>
		<readme>README.md</readme>
		<description>The core CodeBrix.Platform UI package for desktop apps (C# and XAML on .NET 10 / Skia). Self-contained: bundles the CodeBrix.Platform Foundation, WinRT, Dispatching and Foundation.Logging assemblies.</description>
		<copyright>Copyright (c) 2026 Jeremy Ellis and contributors</copyright>
		<tags>ui;xaml;skia;desktop;cross-platform;dotnet;CodeBrix</tags>
		<repository type="git" url="https://github.com/ellisnet/CodeBrix.Platform.git" branch="$branch$" commit="$commitid$" />

		<dependencies>
			<group targetFramework="net10.0">
				<dependency id="CodeBrix.Platform.Fonts.Fluent.ApacheLicenseForever" version="1.0.165.369" />
				<!-- Brought in by the folded Microsoft.Extensions.Logging adapter + Extensions.Logging. -->
				<dependency id="Microsoft.Extensions.Logging" version="10.0.9" />
				<dependency id="CommonServiceLocator" version="2.0.7" />
			</group>
		</dependencies>
	</metadata>
	<files>
		<!-- Icon + readme + third-party notices (package root) -->
		<file src="..\..\icon-codebrix-128.png" target="/" />
		<file src="..\..\README.md" target="/" />
		<file src="..\..\AGENT-README.txt" target="/" />
		<file src="..\..\THIRD-PARTY-NOTICES.txt" target="/" />

