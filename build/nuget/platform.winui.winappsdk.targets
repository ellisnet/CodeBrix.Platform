<?xml version="1.0" encoding="utf-8" ?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
	
	<PropertyGroup>
		<CodeBrixUIMSBuildTasksPath Condition="'$(CodeBrixUIMSBuildTasksPath)'==''">CodeBrix.Platform.UI.Tasks</CodeBrixUIMSBuildTasksPath>
	</PropertyGroup>

	<UsingTask AssemblyFile="$(CodeBrixUIMSBuildTasksPath)\CodeBrix.Platform.UI.Tasks.v0.dll" TaskName="CodeBrix.Platform.UI.Tasks.WinAppSDKValidations.ValidateWinAppSDKReferences_v0" Runtime="NET" TaskFactory="TaskHostFactory" />

	<PropertyGroup>
		<_CodeBrixRemoveReferences_BeforeTargets>
			$(_CodeBrixRemoveReferences_BeforeTargets);
			FindReferenceAssembliesForReferences;
			MarkupCompilePass1;
		</_CodeBrixRemoveReferences_BeforeTargets>

		<!-- Copy from https://github.com/microsoft/WindowsAppSDK/pull/4124 -->
		<ShouldComputeInputPris Condition="'$(ShouldComputeInputPris)' == '' AND ('$(OutputType)' == 'WinExe' OR '$(OutputType)' == 'Exe')">true</ShouldComputeInputPris>
		<ShouldComputeInputPris Condition="'$(ShouldComputeInputPris)' == ''">false</ShouldComputeInputPris>
	</PropertyGroup>

	<Target Name="_CodeBrixRemoveReferences"
			BeforeTargets="$(_CodeBrixRemoveReferences_BeforeTargets)">
		<ItemGroup>
			<_CodeBrixReferencePathToRemove
				Include="@(ReferencePath)"
				Condition="'%(ReferencePath.NuGetPackageId)'=='CodeBrix.Platform.UI' or '%(ReferencePath.NuGetPackageId)'=='CodeBrix.Platform.WinUI'" />

			<!-- Remove all CodeBrix.Platform references -->
			<ReferencePath Remove="@(_CodeBrixReferencePathToRemove)" />
			<ReferenceCopyLocalPaths Remove="@(_CodeBrixReferencePathToRemove)" />

			<!-- Clear items -->
			<_CodeBrixReferencePathToRemove Remove="@(_CodeBrixReferencePathToRemove)" />
		</ItemGroup>

		<ItemGroup Condition="'$(PkgCodeBrix_Platform_ApacheLicenseForever)'!=''">
			<!-- This must be aligned with $winuisourcepath$ in the nuspec -->
			<ReferencePath Include="$(PkgCodeBrix_Platform_ApacheLicenseForever)/lib/net10.0-windows10.0.19041.0/*.dll" />
			<ReferenceCopyLocalPaths Include="$(PkgCodeBrix_Platform_ApacheLicenseForever)/lib/net10.0-windows10.0.19041.0/*.dll" />
		</ItemGroup>

		<ItemGroup Condition="'$(PkgCodeBrix_Platform_ApacheLicenseForever)'!=''">
			<!-- This must be aligned with $winuisourcepath$ in the nuspec -->
			<ReferencePath Include="$(PkgCodeBrix_Platform_ApacheLicenseForever)/lib/UAP/*.dll" />
			<ReferenceCopyLocalPaths Include="$(PkgCodeBrix_Platform_ApacheLicenseForever)/lib/UAP/*.dll" />
		</ItemGroup>
	</Target>

	<Target Name="_CodeBrixIncludeUIToolkit"
			BeforeTargets="$(_CodeBrixRemoveReferences_BeforeTargets)"
			Condition="$(ShouldComputeInputPris)">
		
		<!-- 
		Since we're not using the standard packaging mechanism, the CodeBrix.Platform.UI.Toolkit resources
		need to be included explicitly.
		-->
		
		<ItemGroup>
			<PriOutputs Include="$(PkgCodeBrix_Platform_ApacheLicenseForever)/lib/net10.0-windows10.0.19041.0/CodeBrix.Platform.UI.Toolkit.pri"
						TargetPath="CodeBrix.Platform.UI.Toolkit.pri"
						CopyLocal="True"
						CopyToOutputDirectory="PreserveNewest"
						OutputGroup="CopyLocalFilesOutputGroup" />

			<_CodeBrixUIToolkitAssets Include="$(PkgCodeBrix_Platform_ApacheLicenseForever)/lib/net10.0-windows10.0.19041.0/Platform.UI.Toolkit/**"/>

			<None
				Include="@(_CodeBrixUIToolkitAssets)"
				TargetPath="Platform.UI.Toolkit/%(RecursiveDir)%(Filename)%(Extension)"
				CopyToOutputDirectory="PreserveNewest" />

			<_CodeBrixUIToolkitAssets Remove="@(_CodeBrixUIToolkitAssets)" />
		</ItemGroup>

	</Target>

	<Target Name="_FindInvalidWinAppSDKCodeBrixPlatformReference"
			BeforeTargets="ResolveAssemblyReferences"
			Condition="'$(CodeBrixDisableUNOB0002Validation)'!='true'">

		<!--
		Determine if any ProjectReference contains AdditionalProperties which contains _IsCodeBrixPlatform, a property
		defined only when WinAppSDK is not included.

		This scenario can happen when a WinAppSDK project is referencing a net7.0-only project which contains a reference to
		CodeBrix.Platform, which is not compatible with WinAppSDK. Fixing this requires adding a netX.0-windows10.x target to the project.
		-->
		<ValidateWinAppSDKReferences_v0 ReferencedProjects="@(TargetPathWithTargetPlatformMoniker)" />
	</Target>

	<PropertyGroup Condition=" '$(_ExtrasSdkHasDesktopAppSupport)'==''">
		<TargetsForTfmSpecificContentInPackage>$(TargetsForTfmSpecificContentInPackage);_CodeBrixSdkIncludeWindowsLibraryLayoutItems</TargetsForTfmSpecificContentInPackage>
	</PropertyGroup>

	<!-- source https://github.com/novotnyllc/MSBuildSdkExtras/blob/b58e1d25b530e02ce4d1b937ccf99082019cdc47/Source/MSBuild.Sdk.Extras/Build/Workarounds.targets#L89 -->
	<Target Name="_CodeBrixSdkIncludeWindowsLibraryLayoutItems"
		DependsOnTargets="PrepareLibraryLayout"
		Condition="'$(GenerateLibraryLayout)' == 'true' AND '$(SDKIdentifier)' == 'Windows' AND '$(_ExtrasSdkHasDesktopAppSupport)'==''">
		<ItemGroup>
		<TfmSpecificPackageFile Include="@(_LayoutFile)"
								Condition="'$(ProjectName)' == '%(_LayoutFile.ProjectName)'"
								PackagePath="lib\$(TargetFramework)\%(_LayoutFile.TargetPath)"/>
		</ItemGroup>
	</Target>

	<Target Name="_RemoveRoslynCodeBrixSourceGenerationWinUI" BeforeTargets="CoreCompile;XamlPreCompile">
		<!---
		Remove CodeBrix.Platform source generators when building under WinAppSDK
		-->
		<ItemGroup>
			<_AnalyzerToRemove Include="@(Analyzer)" Condition="'%(FileName)'=='CodeBrix.Platform.UI.SourceGenerators'" />
			<Analyzer Remove="@(_AnalyzerToRemove)"/>
		</ItemGroup>
	</Target>

</Project>
