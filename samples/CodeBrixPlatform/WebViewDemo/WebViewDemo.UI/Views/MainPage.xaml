<Page x:Class="WebViewDemo.Views.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:WebViewDemo.Views"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
      FontFamily="{StaticResource OpenSansFont}">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox x:Name="AddressBox" Grid.Column="0" Height="40"
                     VerticalAlignment="Center" VerticalContentAlignment="Center"
                     Text="https://en.wikipedia.org/wiki/Inanna" />
            <Button Grid.Column="1" Margin="8,0,0,0" Height="40"
                    VerticalAlignment="Center" Content="Go" Click="GoButton_Click" />
            <Button Grid.Column="2" Margin="8,0,0,0" Height="40"
                    VerticalAlignment="Center" Content="Back" Click="BackButton_Click" />
            <Button Grid.Column="3" Margin="8,0,0,0" Height="40"
                    VerticalAlignment="Center" Content="Forward" Click="ForwardButton_Click" />
        </Grid>

        <WebView2 x:Name="Browser" Grid.Row="1" Margin="0,10,0,10"
                  Source="https://en.wikipedia.org/wiki/Inanna" />

        <TextBlock x:Name="StatusText" Grid.Row="2" Text="Ready" />

    </Grid>
</Page>
