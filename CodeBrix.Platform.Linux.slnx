         on Windows via CodeBrix.Platform.Windows.slnx. -->
    <Project Path="src/Platform.Foundation/Platform.Foundation.Tests.csproj" />
    <Project Path="src/Platform.UI.Composition/Platform.UI.Composition.Tests.csproj" />
