<Solution>
  <!-- CodeBrix.Platform.Linux.slnx
       Linux-buildable subset of CodeBrix.Platform.Windows.slnx. Four projects
       from the Windows solution are omitted because they require Windows-host-only
       WinAppSDK build tooling that cannot run on Linux even with
       EnableWindowsTargeting=true (see Directory.Build.props for that flag):

         - tools/ResourcesExtractor/ResourcesExtractor/ResourcesExtractor.csproj
             needs XamlCompiler.exe (Win32 PE binary; exits 126 on Linux).
         - src/Platform.UI.Toolkit/Platform.UI.Toolkit.Windows.csproj
             same XamlCompiler.exe dependency.
         - src/AddIns/Platform.WinUI.Graphics2DSK/Platform.WinUI.Graphics2DSK.Windows.csproj
             needs Microsoft.Build.Packaging.Pri.Tasks.dll (PRI generator), which
             is not present in the Linux .NET SDK's VisualStudio MSBuild path.
         - src/Platform.UI.RuntimeTests/Platform.UI.RuntimeTests.Windows.csproj
             its only ProjectReference is to Uno.UI.Toolkit.Windows above, so
             excluding the dependency forces this consumer out too.

       Build these four on a Windows host using CodeBrix.Platform.Windows.slnx.
       All other Windows-targeting projects (-windows WPF, plus the
       -windows10.0.19041.0 WinAppSDK projects that don't trigger XAML compilation
       or PRI generation — e.g. Uno.UI.MSAL.Windows) build cleanly on Linux with
       EnableWindowsTargeting=true and remain in scope here. -->
  <Folder Name="/Solution Items/">
    <File Path=".editorconfig" />
    <File Path=".gitattributes" />
    <File Path=".gitignore" />
    <File Path=".globalconfig" />
    <File Path="Directory.Build.props" />
    <File Path="global.json" />
    <File Path="LICENSE" />
    <File Path="NuGet.Config" />
    <File Path="THIRD-PARTY-NOTICES.txt" />
    <File Path="version.json" />
  </Folder>
  <Folder Name="/Core/">
    <Project Path="src/Platform.Foundation/Platform.Foundation.csproj" />
    <Project Path="src/Platform.Foundation/Platform.Foundation.Reference.csproj" />
    <Project Path="src/Platform.Foundation/Platform.Foundation.Skia.csproj" />
    <Project Path="src/Platform.Foundation.Logging/Platform.Foundation.Logging.csproj" />
    <Project Path="src/CodeBrix.Platform.Extensions/CodeBrix.Platform.Extensions.csproj" />
    <Project Path="src/CodeBrix.Platform.Extensions.Logging/CodeBrix.Platform.Extensions.Logging.csproj" />
    <Project Path="src/Platform.UI.Composition/Platform.UI.Composition.Reference.csproj" />
    <Project Path="src/Platform.UI.Composition/Platform.UI.Composition.Skia.csproj" />
    <Project Path="src/Platform.UI.Dispatching/Platform.UI.Dispatching.Reference.csproj" />
