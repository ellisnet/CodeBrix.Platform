  </Folder>
  <Folder Name="/UI/">
    <Project Path="src/Platform.UI/Platform.UI.Reference.csproj" />
    <Project Path="src/Platform.UI/Platform.UI.Skia.csproj" />
    <Project Path="src/Platform.UI.Toolkit/Platform.UI.Toolkit.Reference.csproj" />
    <Project Path="src/Platform.UI.Toolkit/Platform.UI.Toolkit.Skia.csproj" />
    <!-- CodeBrix.Platform Linux solution: Uno.UI.Toolkit.Windows excluded — WinAppSDK
         XAML compilation needs Win32 XamlCompiler.exe (exit 126 on Linux). Build on
         Windows via CodeBrix.Platform.Windows.slnx. -->
    <Project Path="src/Platform.UI.XamlHost/Platform.UI.XamlHost.Reference.csproj" />
    <Project Path="src/Platform.UI.XamlHost/Platform.UI.XamlHost.Skia.csproj" />
    <Project Path="src/Platform.UI.XamlHost.Skia.Wpf/Platform.UI.XamlHost.Skia.Wpf.csproj" />
    <Project Path="src/Platform.UI.FluentTheme/Platform.UI.FluentTheme.Reference.csproj" />
    <Project Path="src/Platform.UI.FluentTheme/Platform.UI.FluentTheme.Skia.csproj" />
