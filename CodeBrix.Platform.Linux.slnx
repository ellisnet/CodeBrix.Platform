    <Project Path="src/AddIns/CodeBrix.Platform.SkiaSharp.Views/CodeBrix.Platform.SkiaSharp.Views.Skia.csproj" />
    <Project Path="src/AddIns/Platform.UI.Lottie/Platform.UI.Lottie.Reference.csproj" />
    <Project Path="src/AddIns/Platform.UI.Lottie/Platform.UI.Lottie.Skia.csproj" />
    <Project Path="src/AddIns/Platform.UI.MediaPlayer.Skia.Win32/Platform.UI.MediaPlayer.Skia.Win32.csproj" />
    <Project Path="src/AddIns/Platform.UI.MediaPlayer.Skia.X11/Platform.UI.MediaPlayer.Skia.X11.csproj" />
    <Project Path="src/AddIns/Platform.UI.MSAL/Platform.UI.MSAL.Reference.csproj" />
    <Project Path="src/AddIns/Platform.UI.MSAL/Platform.UI.MSAL.Skia.csproj" />
    <Project Path="src/AddIns/Platform.UI.MSAL/Platform.UI.MSAL.Windows.csproj" />
    <Project Path="src/AddIns/Platform.UI.Svg/Platform.UI.Svg.Reference.csproj" />
    <Project Path="src/AddIns/Platform.UI.Svg/Platform.UI.Svg.Skia.csproj" />
    <Project Path="src/AddIns/Platform.UI.WebView.Skia.Linux/Platform.UI.WebView.Skia.Linux.csproj" />
