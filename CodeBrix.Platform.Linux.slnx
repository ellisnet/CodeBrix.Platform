    <Project Path="src/AddIns/Platform.WinUI.Graphics2DSK/Platform.WinUI.Graphics2DSK.Crossruntime.csproj" />
    <!-- CodeBrix.Platform Linux solution: Uno.WinUI.Graphics2DSK.Windows excluded —
         WinAppSDK PRI generation needs Microsoft.Build.Packaging.Pri.Tasks.dll, which
         the Linux .NET SDK does not ship under Microsoft/VisualStudio/v18.0/AppxPackage/.
         Build on Windows via CodeBrix.Platform.Windows.slnx. -->
    <Project Path="src/AddIns/Platform.WinUI.Graphics3DGL/Platform.WinUI.Graphics3DGL.csproj" />
  </Folder>
  <Folder Name="/Tools/">
    <Project Path="src/Platform.Analyzers/Platform.Analyzers.csproj" />
    <Project Path="src/Platform.Docs.InlineTOCGenerator/Platform.Docs.InlineTOCGenerator.csproj" />
    <Project Path="src/Platform.NUnitTransformTool/Platform.NUnitTransformTool.csproj" />
    <Project Path="src/Platform.ReferenceImplComparer/Platform.ReferenceImplComparer.csproj" />
    <Project Path="src/Platform.UWPSyncGenerator/Platform.UWPSyncGenerator.csproj" />
    <!--I don't think I need this: <Project Path="src/Platform.UWPSyncGenerator.Reference/Platform.UWPSyncGenerator.Reference.csproj" />-->
    <Project Path="src/Platform.ResourceTrimmingValidator/Platform.ResourceTrimmingValidator.csproj" />
    <Project Path="src/Platform.XamlTrimmingValidator/Platform.XamlTrimmingValidator.csproj" />
    <!-- CodeBrix.Platform Linux solution: tools/ResourcesExtractor excluded — WinAppSDK
         XAML compilation needs Win32 XamlCompiler.exe (exit 126 on Linux). Build on
         Windows via CodeBrix.Platform.Windows.slnx. -->
  </Folder>
  <Folder Name="/Tests/">
    <Project Path="src/Platform.UI.Tests/Platform.UI.Unit.Tests.csproj" />
    <Project Path="src/Platform.UI.Tests.ViewLibrary/Platform.UI.Tests.ViewLibrary.csproj" />
    <Project Path="src/Platform.UI.Tests.ViewLibraryProps/Platform.UI.Tests.ViewLibraryProps.csproj" />
    <Project Path="src/Platform.UI/Platform.UI.Tests.csproj" />
    <Project Path="src/Platform.UWP/Platform.Tests.csproj" />
    <Project Path="src/Platform.UI.RuntimeTests/Platform.UI.RuntimeTests.Skia.csproj" />
