<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<TargetFrameworks>$(NetSkiaPreviousAndCurrent)</TargetFrameworks>
	</PropertyGroup>

	<Import Project="../../targetframework-override.props" />

	<PropertyGroup>
		<Deterministic>true</Deterministic>

		<AssemblyName>CodeBrix.Platform.UI.Svg</AssemblyName>
		<RootNamespace>CodeBrix.Platform.UI.Svg</RootNamespace>

		<CodeBrixRuntimeIdentifier>Skia</CodeBrixRuntimeIdentifier>
		<PlatformItemsBasePath>.\</PlatformItemsBasePath>
		<Nullable>enable</Nullable>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="CodeBrix.SkiaSvg.MitLicenseForever" Version="1.0.180.239" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\..\Platform.Foundation\Platform.Foundation.Skia.csproj" />
		<ProjectReference Include="..\..\Platform.UI\Platform.UI.Skia.csproj" />
		<ProjectReference Include="..\CodeBrix.Platform.SkiaSharp.Views\CodeBrix.Platform.SkiaSharp.Views.Skia.csproj" />
		<ProjectReference Include="..\Platform.WinUI.Graphics2DSK\Platform.WinUI.Graphics2DSK.Crossruntime.csproj" />
	</ItemGroup>

	<Target Name="_CodeBrixUISvgOverrideNuget" AfterTargets="AfterBuild" DependsOnTargets="BuiltProjectOutputGroup" Condition="'$(CodeBrixNugetOverrideVersion)'!=''">

		<PropertyGroup>
			<_OverrideTargetFramework>$(TargetFramework)</_OverrideTargetFramework>
			<_TargetNugetFolder>$(NuGetPackageRoot)\codebrix.platform.ui.svg\$(CodeBrixNugetOverrideVersion)\codebrix-platform-runtime\$(CodeBrixRuntimeIdentifier.ToLowerInvariant())</_TargetNugetFolder>
		</PropertyGroup>
		<ItemGroup>
			<_OutputFiles Include="$(TargetDir)**" />
		</ItemGroup>
		<MakeDir Directories="$(_TargetNugetFolder)" />

		<Message Importance="high" Text="OVERRIDING NUGET PACKAGE CACHE: $(_TargetNugetFolder)" />

		<Copy SourceFiles="@(_OutputFiles)" DestinationFiles="@(_OutputFiles->'$(_TargetNugetFolder)\%(RecursiveDir)%(Filename)%(Extension)')" />
		<Copy SourceFiles="@(_OutputFilesPDB)" DestinationFiles="@(_OutputFilesPDB->'$(_TargetNugetFolder)\%(RecursiveDir)%(Filename).pdb')" />
	</Target>

</Project>
