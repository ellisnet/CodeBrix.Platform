<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFrameworks>$(NetReferencePreviousAndCurrent)</TargetFrameworks>
	</PropertyGroup>

	<Import Project="../../targetframework-override.props" />

	<PropertyGroup>
		<NoWarn>$(NoWarn);Uno0001</NoWarn>
		<Deterministic>true</Deterministic>
		<Nullable>enable</Nullable>
		<AssemblyName>CodeBrix.Platform.UI.Lottie</AssemblyName>
		<RootNamespace>CodeBrix.Platform.UI.Lottie</RootNamespace>

		<DefineConstants Condition="'$(CODEBRIX_UWP_BUILD)'!='true'">$(DefineConstants);HAS_SKOTTIE</DefineConstants>

		<CodeBrixRuntimeIdentifier>Reference</CodeBrixRuntimeIdentifier>
	</PropertyGroup>

	<ItemGroup>
		 <None Remove="buildTransitive\*.Lottie.targets" />
	</ItemGroup>

	<ItemGroup>
		<Content Include="buildTransitive\*.Lottie.targets">
			<PackagePath>build</PackagePath>
			<Pack>true</Pack>
		</Content>
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\..\Platform.UI\Platform.UI.Reference.csproj" />
		<ProjectReference Include="..\CodeBrix.Platform.SkiaSharp.Views\CodeBrix.Platform.SkiaSharp.Views.Reference.csproj" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Newtonsoft.Json" />

		<PackageReference Include="SkiaSharp.Skottie" />
	</ItemGroup>

	<Import Project="..\..\SourceGenerators\Platform.UI.SourceGenerators\Content\Platform.UI.SourceGenerators.props" />

	<Target Name="_CodeBrixToolkitOverrideNuget" AfterTargets="AfterBuild" DependsOnTargets="BuiltProjectOutputGroup" Condition="'$(CodeBrixNugetOverrideVersion)'!=''">

		<PropertyGroup>
			<_OverrideTargetFramework>$(TargetFramework)</_OverrideTargetFramework>
			<_TargetNugetFolder>$(NuGetPackageRoot)\codebrix.platform.ui.lottie\$(CodeBrixNugetOverrideVersion)\lib\$(_OverrideTargetFramework)</_TargetNugetFolder>
		</PropertyGroup>
		<ItemGroup>
			<_OutputFiles Include="$(TargetDir)**" />
		</ItemGroup>
		<MakeDir Directories="$(_TargetNugetFolder)" />

		<Message Importance="high" Text="OVERRIDING NUGET PACKAGE CACHE: $(_TargetNugetFolder)" />

		<Copy SourceFiles="@(_OutputFiles)" DestinationFiles="@(_OutputFiles->'$(_TargetNugetFolder)\%(RecursiveDir)%(Filename)%(Extension)')" />
		<Copy SourceFiles="@(_OutputFilesPDB)" DestinationFiles="@(_OutputFilesPDB->'$(_TargetNugetFolder)\%(RecursiveDir)%(Filename).pdb')" />
	</Target>
</Project>
