<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<TargetFrameworks>$(NetSkiaPreviousAndCurrent)</TargetFrameworks>
	</PropertyGroup>

	<Import Project="../../targetframework-override-noplatform.props" />

	<PropertyGroup>
		<AssemblyName>CodeBrix.Platform.UI.WebView.Skia.Linux</AssemblyName>
		<RootNamespace>CodeBrix.Platform.UI.WebView.Skia.Linux</RootNamespace>

		<!-- This AddIn is packed by the central driver (build/CodeBrix.Platform.Build.csproj, the
		     _CsprojPackage list), which date-stamps it and drops it in {repo}/nugets/Release with
		     the rest of the family - so no GeneratePackageOnBuild here. -->
		<!-- Ships the standard CodeBrix doc set (icon, README, AGENT-README, THIRD-PARTY-NOTICES) as
		     package content via the ItemGroup below. The packed root README.md also serves as the
		     nuget readme (PackageReadmeFile=README.md inherited from src/Directory.Build.props),
		     matching the Lottie package's configuration. -->
		<PackageIcon>icon-codebrix-128.png</PackageIcon>
		<PackageId Condition="'$(CODEBRIX_UWP_BUILD)'=='false'">CodeBrix.Platform.WebView.ApacheLicenseForever</PackageId>
		<Description>This package provides WebView support for CodeBrix.Platform Skia apps on Linux - all three heads: X11, Wayland, and FrameBuffer. Web content is rendered offscreen by the system-installed WPE WebKit engine (sudo apt install libwpewebkit-2.0-1 libwpebackend-fdo-1.0-1 libwpe-1.0-1) and composited directly into the Skia scene; no engine binaries are shipped in this package. Reference it once, in your app's .Core project, like the other extension add-ons: every head gets it, the Linux heads activate it, and it is inert on the Windows, Skia-on-WPF, and macOS heads (which have built-in WebView support).</Description>

		<CodeBrixRuntimeIdentifier>Skia</CodeBrixRuntimeIdentifier>
		<PlatformItemsBasePath>.\</PlatformItemsBasePath>
	</PropertyGroup>

	<PropertyGroup>
		<Nullable>enable</Nullable>
		<AllowUnsafeBlocks>true</AllowUnsafeBlocks>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="SkiaSharp" />

		<!-- Platform.UI.Skia packs as the CodeBrix.Platform.ApacheLicenseForever dependency, at the
		     same family version as this build (the whole family ships together). Extensions.Logging is
		     PrivateAssets="all" because it has no standalone nuget - its assembly ships inside the main
		     framework package. -->
		<ProjectReference Include="..\..\Platform.UI\Platform.UI.Skia.csproj" />
		<ProjectReference Include="..\..\CodeBrix.Platform.Extensions.Logging\CodeBrix.Platform.Extensions.Logging.csproj" PrivateAssets="all" />
	</ItemGroup>

	<ItemGroup>
		<None Include="..\..\..\icon-codebrix-128.png" Pack="true" PackagePath="\" Visible="false" />
		<None Include="..\..\..\README.md" Pack="true" PackagePath="\" Visible="false" />
		<None Include="..\..\..\AGENT-README.txt" Pack="true" PackagePath="\" Visible="false" />
		<None Include="..\..\..\THIRD-PARTY-NOTICES.txt" Pack="true" PackagePath="\" Visible="false" />
	</ItemGroup>
</Project>
