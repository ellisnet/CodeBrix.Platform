<Project Sdk="Microsoft.NET.Sdk">
	<!-- Identity pinned to legacy names; rename step changed only the .csproj filename. -->
	<PropertyGroup>
		<AssemblyName>CodeBrix.Platform.WinUI.Graphics3DGL</AssemblyName>
		<PackageId>CodeBrix.Platform.WinUI.Graphics3DGL</PackageId>
	</PropertyGroup>

    <PropertyGroup>
		<TargetFrameworks>$(NetSkiaPreviousAndCurrent)</TargetFrameworks>
		<TargetFrameworks Condition="'$(BuildGraphics3DGLForWindows)' != ''">$(TargetFrameworks);$(NetUWPOrWinUI)</TargetFrameworks>

		<RootNamespace>CodeBrix.Platform.WinUI.Graphics3DGL</RootNamespace>
		<GeneratePackageOnBuild Condition="'$(Configuration)'=='Release'">true</GeneratePackageOnBuild>
		<!-- Ships the standard CodeBrix doc set (icon, README, AGENT-README, THIRD-PARTY-NOTICES) as package content via the ItemGroup below. PackageReadmeFile is intentionally left unset so the docs pack as plain content and GeneratePackageOnBuild stays green. -->
		<PackageIcon>icon-codebrix-128.png</PackageIcon>
		<PackageReadmeFile></PackageReadmeFile>

		<Nullable>enable</Nullable>
		
		<!-- Required as the project name does not end with `.Skia` when building for netcoremobile targets -->
		<CodeBrixDisableTargetFrameworkPlatformOverride Condition="!$(CodeBrixTargetFrameworkOverride.Contains('windows10'))">true</CodeBrixDisableTargetFrameworkPlatformOverride>
    </PropertyGroup>

	<Import Project="../../targetframework-override.props" />

	<ItemGroup>
		<PackageReference Include="CodeBrix.Platform.OpenGL.MitLicenseForever" Version="1.0.165.1357" />
	</ItemGroup>

	<ItemGroup Condition="!$(TargetFramework.Contains('windows10'))">
		<ProjectReference Include="..\..\Platform.UI\Platform.UI.Skia.csproj" PrivateAssets="all" />
	</ItemGroup>

	<Choose>
		<!-- Android -->
		<When Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)'))=='android'">
			<PropertyGroup>
				<DefineConstants>$(DefineConstants);ANDROID</DefineConstants>
			</PropertyGroup>
		</When>
		<!-- Skia Desktop -->
		<When Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)'))==''">
			<PropertyGroup>
				<DefineConstants>$(DefineConstants);CROSSRUNTIME</DefineConstants>
			</PropertyGroup>
		</When>
		<!-- WinUI -->
		<When Condition="$(TargetFramework.Contains('windows10'))">
			<PropertyGroup>
				<RuntimeIdentifiers>win-x86;win-x64;win-arm64</RuntimeIdentifiers>

				<DefineConstants Condition="'$(CODEBRIX_UWP_BUILD)'!='true'">$(DefineConstants);WINDOWS_UWP</DefineConstants>
				<DefineConstants Condition="'$(CODEBRIX_UWP_BUILD)'=='true'">$(DefineConstants);WINAPPSDK</DefineConstants>
				<DefineConstants>$(DefineConstants);WINAPPSDK</DefineConstants>
				<UseRidGraph>true</UseRidGraph>
				<WindowsPackageType>None</WindowsPackageType>
			</PropertyGroup>
			<ItemGroup>
				<PackageReference Include="Microsoft.WindowsAppSDK" Version="2.2.0" Condition="'$(CODEBRIX_UWP_BUILD)'!='true'" />
				<PackageReference Include="Microsoft.Windows.SDK.BuildTools" Version="10.0.28000.1839" PrivateAssets="all" Condition="'$(CODEBRIX_UWP_BUILD)'!='true'" />

				<Compile Include="..\..\Platform.UI.Runtime.Skia.Wpf\Rendering\WindowsRenderingNativeMethods.cs" />
				<Compile Include="..\..\Platform.UI.Runtime.Skia.Wpf\Extensions\WpfNativeOpenGLWrapper.cs" />
				<Compile Include="..\..\Platform.UI\Graphics\INativeOpenGLWrapper.cs" />
			</ItemGroup>
		</When>
	</Choose>

	<PropertyGroup>
		<DefineConstants Condition="$(CODEBRIX_UWP_BUILD) == true">$(DefineConstants);CODEBRIX_UWP_BUILD</DefineConstants>
	</PropertyGroup>

	<PropertyGroup>
		<DefaultItemExcludes>$(DefaultItemExcludes);angle/**</DefaultItemExcludes>
	</PropertyGroup>

	<Target Name="GetAngle" BeforeTargets="Build">
		<DownloadFile Condition="!exists('$(MSBuildThisFileDirectory)angle_binaries/osx/libEGL.dylib')" SourceUrl="https://github.com/dotnet/Silk.NET/raw/a9c75a61528ee7b4e55442f5141cb132f10d72ff/src/Native/Silk.NET.OpenGLES.ANGLE.Native/runtimes/osx/native/libEGL.dylib" DestinationFolder="$(MSBuildThisFileDirectory)angle_binaries/osx">
		</DownloadFile>
		<DownloadFile Condition="!exists('$(MSBuildThisFileDirectory)angle_binaries/osx/libGLESv2.dylib')" SourceUrl="https://github.com/dotnet/Silk.NET/raw/a9c75a61528ee7b4e55442f5141cb132f10d72ff/src/Native/Silk.NET.OpenGLES.ANGLE.Native/runtimes/osx/native/libGLESv2.dylib" DestinationFolder="$(MSBuildThisFileDirectory)angle_binaries/osx">
		</DownloadFile>
	</Target>

	<Target Name="CleanAngle" AfterTargets="Clean">
		<RemoveDir Directories="$(MSBuildThisFileDirectory)angle_binaries" />
	</Target>

	<ItemGroup>
		<None Include="..\..\..\icon-codebrix-128.png" Pack="true" PackagePath="\" />
		<None Include="..\..\..\README.md" Pack="true" PackagePath="\" />
		<None Include="..\..\..\AGENT-README.txt" Pack="true" PackagePath="\" />
		<None Include="..\..\..\THIRD-PARTY-NOTICES.txt" Pack="true" PackagePath="\" />
		<Content Include="Assets\**\*.*" CopyToOutputDirectory="PreserveNewest" />
	</ItemGroup>
	
	<ItemGroup>
		<None Include="$(MSBuildThisFileDirectory)angle_binaries/osx/lib*" PackagePath="runtimes/osx/native" Pack="true" Visible="False" />
	</ItemGroup>
	<ItemGroup>
		<ProjectReference Include="../../CodeBrix.Platform.Extensions.Logging/CodeBrix.Platform.Extensions.Logging.csproj" />
	</ItemGroup>
</Project>
