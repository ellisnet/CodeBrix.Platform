<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<TargetFrameworks>$(NetSkiaPreviousAndCurrent)</TargetFrameworks>
	</PropertyGroup>

	<Import Project="../targetframework-override.props" />

	<PropertyGroup>
		<AssemblyName>CodeBrix.Platform.UI.FluentTheme</AssemblyName>
		<RootNamespace>CodeBrix.Platform.UI.FluentTheme</RootNamespace>

		<ProduceReferenceAssembly>false</ProduceReferenceAssembly>
		<Deterministic>true</Deterministic>

		<CodeBrixRuntimeIdentifier>Skia</CodeBrixRuntimeIdentifier>

		<CodeBrixXamlResourcesTrimming>true</CodeBrixXamlResourcesTrimming>

		<UseCommonOverridePackage>true</UseCommonOverridePackage>
		<CommonOverridePackageId>CodeBrix.Platform.UI</CommonOverridePackageId>
	</PropertyGroup>

	<ItemGroup>
		<ProjectReference Include="..\Platform.UI\Platform.UI.Skia.csproj" />
		<ProjectReference Include="..\Platform.UI.FluentTheme.v1\Platform.UI.FluentTheme.v1.Skia.csproj" />
		<ProjectReference Include="..\Platform.UI.FluentTheme.v2\Platform.UI.FluentTheme.v2.Skia.csproj" />
	</ItemGroup>

	<Import Project="FluentMerge.targets" />

	<Import Project="..\SourceGenerators\Platform.UI.Tasks\Content\Platform.UI.Tasks.targets" Condition="'$(SkipCodeBrixResourceGeneration)' == '' " />

</Project>
