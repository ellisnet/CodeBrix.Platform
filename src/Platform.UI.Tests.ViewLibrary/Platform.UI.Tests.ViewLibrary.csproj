<Project Sdk="Microsoft.NET.Sdk">
	<!-- Identity pinned to legacy names; rename step changed only the .csproj filename. -->
	<PropertyGroup>
		<AssemblyName>CodeBrix.Platform.UI.Tests.ViewLibrary</AssemblyName>
		<RootNamespace>CodeBrix.Platform.UI.Tests.ViewLibrary</RootNamespace>
	</PropertyGroup>

	<PropertyGroup>
		<TargetFrameworks>$(NetUnitTests)</TargetFrameworks>
		<OutputPath>bin\$(Platform)\$(Configuration)</OutputPath>
		<ImportFrameworkWinFXTargets>false</ImportFrameworkWinFXTargets>
	</PropertyGroup>
	<Import Project="../targetframework-override.props" />

	<PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Debug|AnyCPU' ">
		<DebugSymbols>true</DebugSymbols>
		<DebugType>full</DebugType>
		<Optimize>false</Optimize>
		<DefineConstants>TRACE;DEBUG;HAS_UMBRELLA_BINDING;IS_UNIT_TESTS;HAS_GEOCOORDINATE_WATCHER;HAS_GEOCOORDINATE;HAS_COMPILED_REGEX;HAS_ISTORAGEFILE;HAS_SEMAPHORE;HAS_FILE_IO;IS_CODEBRIX;HAS_CRIPPLEDREFLECTION;NET46</DefineConstants>
	</PropertyGroup>
	<PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Release|AnyCPU' ">
		<DebugSymbols>true</DebugSymbols>
		<DebugType>full</DebugType>
		<Optimize>false</Optimize>
		<DefineConstants>TRACE;HAS_UMBRELLA_BINDING;IS_UNIT_TESTS;HAS_GEOCOORDINATE_WATCHER;HAS_GEOCOORDINATE;HAS_COMPILED_REGEX;HAS_ISTORAGEFILE;HAS_SEMAPHORE;HAS_FILE_IO;IS_CODEBRIX;HAS_CRIPPLEDREFLECTION</DefineConstants>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.Extensions.Logging.Debug" Version="1.1.1" />
		<PackageReference Include="Microsoft.Extensions.Logging.Console" Version="1.1.1" />
	</ItemGroup>


	<PropertyGroup>
		<CodeBrixUIMSBuildTasksPath>$(MSBuildThisFileDirectory)..\SourceGenerators\Platform.UI.Tasks\bin\$(Configuration)_Shadow</CodeBrixUIMSBuildTasksPath>
		<CodeBrixForceProcessPRIResource>true</CodeBrixForceProcessPRIResource>
	</PropertyGroup>

	<Import Project="..\SourceGenerators\Platform.UI.SourceGenerators\Content\Platform.UI.SourceGenerators.props" />
	<Import Project="..\SourceGenerators\Platform.UI.Tasks\Content\Platform.UI.Tasks.targets" Condition="'$(SkipCodeBrixResourceGeneration)' == '' " />

	<Target Name="BeforeBuildCleanup" BeforeTargets="XamlMarkupCompilePass1" />

	<ItemGroup>
		<ProjectReference Include="..\SourceGenerators\System.Xaml\Platform.Xaml.csproj" />
		<ProjectReference Include="..\Platform.UI\Platform.UI.Tests.csproj" />
	</ItemGroup>
</Project>
