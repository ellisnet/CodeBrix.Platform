<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<TargetFrameworks>$(NetSkiaPreviousAndCurrent)</TargetFrameworks>
	</PropertyGroup>

	<Import Project="../targetframework-override.props" />

	<PropertyGroup>
		<AssemblyName>CodeBrix.Platform</AssemblyName>
		<RootNamespace>Windows</RootNamespace>
		<DefineConstants>$(DefineConstants);XAMARIN;IS_CODEBRIX;HAS_UMBRELLA_UI;HAS_UMBRELLA_BINDING;HAS_CRIPPLEDREFLECTION</DefineConstants>
		<CodeBrixDisableAnalyzersForSamples>true</CodeBrixDisableAnalyzersForSamples>


		<ProduceReferenceAssembly>false</ProduceReferenceAssembly>
		<Deterministic>true</Deterministic>

		<CodeBrixRuntimeIdentifier>Skia</CodeBrixRuntimeIdentifier>
		<PlatformItemsBasePath>.\</PlatformItemsBasePath>
		
		<UseCommonOverridePackage>true</UseCommonOverridePackage>
		<CommonOverridePackageId>codebrix.platform.winrt</CommonOverridePackageId>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="SkiaSharp" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\Platform.Foundation\Platform.Foundation.Skia.csproj" />
		<ProjectReference Include="..\Platform.UI.Dispatching\Platform.UI.Dispatching.Skia.csproj" />
	</ItemGroup>
	
	<ItemGroup>
		<Compile Include="..\Platform.UI\UI\Input\WinRT\*.cs" />
		<Compile Include="..\Platform.UI\UI\Colors.cs" />
		<Compile Include="..\Platform.UI\UI\ColorHelper.cs" />
		<Compile Include="..\Platform.UI\UI\Text\FontWeights.cs" />
	</ItemGroup>

	<ItemGroup>
	  <None Remove="ApplicationModel\Core\CoreApplication.Reference.cs" />
	</ItemGroup>

	<ItemGroup>
		<PRIResource Include="Storage\Pickers\Strings\**\*.resw" />
	</ItemGroup>

	<ItemGroup>
	  <Folder Include="Storage\Pickers\Strings\en\" />
	</ItemGroup>

</Project>
