<?xml version="1.0" encoding="utf-8" ?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
	<PropertyGroup>
		<IsCodeBrixHead Condition="'$(OutputType)'=='Exe' OR '$(OutputType)'=='WinExe'">true</IsCodeBrixHead>
	</PropertyGroup>

	<Target Name="_CodeBrixSkiaWin32FeatureDefines" AfterTargets="PrepareForBuild">

		<PropertyGroup>
			<DefineConstants>$(DefineConstants);CODEBRIX_REFERENCE_API;HAS_CODEBRIX_SKIA;HAS_CODEBRIX_SKIA_WIN32;__DESKTOP__;__CODEBRIX_SKIA__;__CODEBRIX_SKIA_WIN32__</DefineConstants>
		</PropertyGroup>

	</Target>

	<!-- Copy Content files to the output folder like APPX packaging does. -->
	<Target Name="_CodeBrixBeforeCopyLocal" BeforeTargets="CopyFilesToOutputDirectory;_CopyFilesMarkedCopyLocal">
		<ItemGroup>
			<ContentWithTargetPath
				Update="@(ContentWithTargetPath)"
				CopyToOutputDirectory="Always" />
		</ItemGroup>
	</Target>

</Project>
