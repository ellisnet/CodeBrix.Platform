<Project Sdk="Microsoft.NET.Sdk">
	<!-- Identity pinned to legacy names; rename step changed only the .csproj filename. -->
	<PropertyGroup>
		<RootNamespace>CodeBrix.Platform.UI.SourceGenerators</RootNamespace>
	</PropertyGroup>

	<PropertyGroup>
		<!-- Generators must be on netstandard2.0 so that they run in VS (.NET Framework) and dotnet build (.NET Core) -->
		<TargetFramework>netstandard2.0</TargetFramework>
		<AssemblyName>CodeBrix.Platform.UI.SourceGenerators</AssemblyName>
		<AppendTargetFrameworkToOutputPath>true</AppendTargetFrameworkToOutputPath>
		<CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>

		<!-- We need all the intermediate assemblies -->
		<DisablePrivateProjectReference>true</DisablePrivateProjectReference>

		<!-- Too noisy for us right now -->
		<EnforceExtendedAnalyzerRules>false</EnforceExtendedAnalyzerRules>

		<!-- TODO: Migrate the ISourceGenerator implementations in this project to IIncrementalGenerator, then remove RS1042 from this NoWarn list. -->
		<NoWarn>$(NoWarn);RS1042</NoWarn>
	</PropertyGroup>


	<ItemGroup>
		<PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="5.3.0" ExcludeAssets="runtime" />
		<PackageReference Include="Microsoft.CodeAnalysis.Analyzers" Version="5.3.0" PrivateAssets="all" />
	</ItemGroup>

	<ItemGroup>
		<Compile Include="..\..\Platform.Foundation\Internals\BindableAttribute.cs">
			<Link>XamlGenerator\XamlPathParser\BindableAttribute.cs</Link>
		</Compile>
		<Compile Include="..\..\Platform.Foundation\Point.cs">
			<Link>XamlGenerator\XamlPathParser\Point.cs</Link>
		</Compile>
		<Compile Include="..\..\Platform.Foundation\Size.cs">
			<Link>XamlGenerator\XamlPathParser\Size.cs</Link>
		</Compile>
		<Compile Include="..\..\Platform.Foundation\SizeConverter.cs">
			<Link>XamlGenerator\XamlPathParser\SizeConverter.cs</Link>
		</Compile>
		<Compile Include="..\..\Platform.UI\Media\PathMarkupParser.cs">
			<Link>XamlGenerator\XamlPathParser\PathMarkupParser.cs</Link>
		</Compile>
		<Compile Include="..\..\Platform.UI\Media\StreamGeometryContext.cs">
			<Link>XamlGenerator\XamlPathParser\StreamGeometryContext.cs</Link>
		</Compile>
		<Compile Include="..\..\Platform.UI\UI\Xaml\Media\FillRule.cs">
			<Link>XamlGenerator\XamlPathParser\FillRule.cs</Link>
		</Compile>
		<Compile Include="..\..\Platform.UI\UI\Xaml\Media\SweepDirection.cs">
			<Link>XamlGenerator\XamlPathParser\SweepDirection.cs</Link>
		</Compile>
		<Compile Include="..\..\Platform.Foundation\Metadata\ApiInformation.shared.cs">
			<Link>XamlGenerator\ApiInformation.shared.cs</Link>
		</Compile>
		<Compile Include="..\..\Platform.UI\UI\Xaml\GridLength.cs">
			<Link>Helpers\GridLength.cs</Link>
		</Compile>
		<Compile Include="..\..\Platform.UI\UI\Xaml\GridLengthHelper.cs">
			<Link>Helpers\GridLengthHelper.cs</Link>
		</Compile>
		<Compile Include="..\..\Platform.UI\UI\Xaml\GridUnitType.cs">
			<Link>Helpers\GridUnitType.cs</Link>
		</Compile>
		<Compile Include="..\..\Platform.UI\UI\Xaml\XamlFilePathHelper.shared.cs">
			<Link>Helpers\XamlFilePathHelper.shared.cs</Link>
		</Compile>
	</ItemGroup>

	<Import Project="..\SourceGeneratorHelpers\SourceGeneratorHelpers.projitems" Label="Shared" />

	<ItemGroup>
		<None Include="Content\Platform.UI.SourceGenerators.props" />
	</ItemGroup>

	<ItemGroup>
		<InternalsVisibleTo Include="CodeBrix.Platform.UI.SourceGenerators.Tests" />
		<InternalsVisibleTo Include="CodeBrix.Platform.UI.Unit.Tests" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\System.Xaml\Platform.Xaml.csproj">
			<Project>{1627740a-19d2-4d21-a0b2-66667038daf6}</Project>
			<Name>CodeBrix.Platform.Xaml</Name>
			<Aliases>__codebrix</Aliases>
			<SetTargetFramework>TargetFramework=netstandard2.0</SetTargetFramework>
		</ProjectReference>
	</ItemGroup>

	<Target Name="_CodeBrixToolkitOverrideNuget" AfterTargets="AfterBuild" DependsOnTargets="BuiltProjectOutputGroup" Condition="'$(CodeBrixNugetOverrideVersion)'!=''">
		<PropertyGroup>
			<_OverridePackageId>codebrix.platform.ui</_OverridePackageId>
			<_OverridePackageId Condition="'$(CODEBRIX_UWP_BUILD)'=='false'">codebrix.platform.winui</_OverridePackageId>

			<_TargetNugetFolder>$(NuGetPackageRoot)\$(_OverridePackageId)\$(CodeBrixNugetOverrideVersion)\analyzers\dotnet\cs</_TargetNugetFolder>
		</PropertyGroup>
		<ItemGroup>
			<_OutputFiles Include="$(TargetDir)**" />
		</ItemGroup>
		<MakeDir Directories="$(_TargetNugetFolder)" />
		<Message Importance="high" Text="OVERRIDING NUGET PACKAGE CACHE: $(_TargetNugetFolder)" />
		<Copy SourceFiles="@(_OutputFiles)" DestinationFiles="@(_OutputFiles->'$(_TargetNugetFolder)\%(RecursiveDir)%(Filename)%(Extension)')" />
		<Copy SourceFiles="@(_OutputFilesPDB)" DestinationFiles="@(_OutputFilesPDB->'$(_TargetNugetFolder)\%(RecursiveDir)%(Filename).pdb')" />
	</Target>

	<Target Name="GetTargetPath" />
	<Target Name="GetCopyToPublishDirectoryItems" />
</Project>
