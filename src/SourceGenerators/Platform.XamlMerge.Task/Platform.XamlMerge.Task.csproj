<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Microsoft.NET.Sdk">
	<!-- Identity pinned to legacy names; rename step changed only the .csproj filename. -->
	<PropertyGroup>
		<RootNamespace>CodeBrix.Platform.XamlMerge.Task</RootNamespace>
	</PropertyGroup>

	<PropertyGroup>
		<!--
		CodeBrix.Platform fork: vendored from https://github.com/unoplatform/uno.xamlmerge.task
		at commit f76645703193d279913d46c9181e0642bc79c095 (the commit the previously consumed
		Uno.XamlMerge.Task 1.27.0-dev.44 package was built from) so the platform build has no
		dependency on the Uno-org NuGet package. Built in-repo and used only by
		src/Platform.UI/XamlMerge.targets; never packaged or shipped. Retargeted
		netstandard2.0 → $(NetCurrent) per this fork's dotnet-only MSBuild-tasks convention
		(see src/SourceGenerators/Platform.UI.Tasks). See PORTING-NOTES.md in this folder.
		-->
		<TargetFramework>$(NetCurrent)</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<IsTool>true</IsTool>
		<AssemblyName>CodeBrix.Platform.XamlMerge.Task.v0</AssemblyName>
		<AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.Build" Version="18.7.1" ExcludeAssets="runtime" PrivateAssets="all" />
		<PackageReference Include="Microsoft.Build.Framework" Version="18.7.1" ExcludeAssets="runtime" PrivateAssets="all" />
		<PackageReference Include="Microsoft.Build.Tasks.Core" Version="18.7.1" ExcludeAssets="runtime" PrivateAssets="all" />
		<PackageReference Include="Microsoft.Build.Utilities.Core" Version="18.7.1" ExcludeAssets="runtime" PrivateAssets="all" />
		<!-- Upstream also referenced Mono.Cecil (PrivateAssets) but no source uses it; dropped. -->
	</ItemGroup>

	<Target Name="_copyTasksBuildTime" AfterTargets="Build">
		<ItemGroup>
			<_codebrixTasksFiles Include="$(OutputPath)\*.*" />
		</ItemGroup>
		<!--
		Copy the files to an alternate location, using deterministic build, so the
		UsingTask consumers load the shadow copy and never lock the build output.
		Don't fail the build if the file is locked.
		-->
		<Copy SkipUnchangedFiles="true" SourceFiles="@(_codebrixTasksFiles)" DestinationFolder="$(OutputPath)\..\$(Configuration)_Shadow" Retries="1" RetryDelayMilliseconds="500" ContinueOnError="true" />
	</Target>

</Project>
