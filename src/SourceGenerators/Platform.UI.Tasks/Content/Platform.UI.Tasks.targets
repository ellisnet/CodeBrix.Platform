<?xml version="1.0" encoding="utf-8" ?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
	<PropertyGroup>
		<CodeBrixUIMSBuildTasksPath Condition="'$(CodeBrixUIMSBuildTasksPath)'==''">CodeBrix.Platform.UI.Tasks</CodeBrixUIMSBuildTasksPath>
		<UmbrellaMSBuildTasksImported>true</UmbrellaMSBuildTasksImported>

		<_IsXamlTrimmingAvailable>true</_IsXamlTrimmingAvailable>
		<_IsXamlTrimmingAvailable Condition="'$(MSBuildRuntimeType)'!='Core' and !$([MSBuild]::IsOSPlatform('windows'))">false</_IsXamlTrimmingAvailable>
	</PropertyGroup>

	<Import Project="platform.ui.tasks.assets.targets"/>

	<UsingTask AssemblyFile="$(CodeBrixUIMSBuildTasksPath)\CodeBrix.Platform.UI.Tasks.v0.dll" TaskName="CodeBrix.Platform.UI.Tasks.LinkerHintsGenerator.LinkerHintGeneratorTask_v0" Runtime="NET" TaskFactory="TaskHostFactory" />
	<UsingTask AssemblyFile="$(CodeBrixUIMSBuildTasksPath)\CodeBrix.Platform.UI.Tasks.v0.dll" TaskName="CodeBrix.Platform.UI.Tasks.LinkerHintsGenerator.LinkerDefinitionMergerTask_v0" Runtime="NET" TaskFactory="TaskHostFactory" />
	<UsingTask AssemblyFile="$(CodeBrixUIMSBuildTasksPath)\CodeBrix.Platform.UI.Tasks.v0.dll" TaskName="CodeBrix.Platform.UI.Tasks.EmbeddedResourceInjector.EmbeddedResourceInjectorTask_v0" Runtime="NET" TaskFactory="TaskHostFactory" />

	<UsingTask Condition="'$(_IsCodeBrixUISolution)'==''" AssemblyFile="$(CodeBrixUIMSBuildTasksPath)\CodeBrix.Platform.UI.Tasks.v0.dll" TaskName="CodeBrix.Platform.UI.Tasks.ResourcesGenerator.ResourcesGenerationTask_v0" Runtime="NET" TaskFactory="TaskHostFactory" />
	<UsingTask Condition="'$(_IsCodeBrixUISolution)'==''" AssemblyFile="$(CodeBrixUIMSBuildTasksPath)\CodeBrix.Platform.UI.Tasks.v0.dll" TaskName="CodeBrix.Platform.UI.Tasks.ResourcesGenerator.UpriFeaturesGeneratorTask_v0" Runtime="NET" TaskFactory="TaskHostFactory" />
	<UsingTask Condition="'$(_IsCodeBrixUISolution)'==''" AssemblyFile="$(CodeBrixUIMSBuildTasksPath)\CodeBrix.Platform.UI.Tasks.v0.dll" TaskName="CodeBrix.Platform.UI.Tasks.ResourcesGenerator.UpriSubstitutionsGeneratorTask_v0" Runtime="NET" TaskFactory="TaskHostFactory" />
	<UsingTask Condition="'$(_IsCodeBrixUISolution)'==''" AssemblyFile="$(CodeBrixUIMSBuildTasksPath)\CodeBrix.Platform.UI.Tasks.v0.dll" TaskName="CodeBrix.Platform.UI.Tasks.Assets.RetargetAssets_v0" Runtime="NET" TaskFactory="TaskHostFactory" />
	<UsingTask Condition="'$(_IsCodeBrixUISolution)'==''" AssemblyFile="$(CodeBrixUIMSBuildTasksPath)\CodeBrix.Platform.UI.Tasks.v0.dll" TaskName="CodeBrix.Platform.UI.Tasks.RuntimeAssetsSelector.RuntimeAssetsSelectorTask_v0" Runtime="NET" TaskFactory="TaskHostFactory" />
	<UsingTask Condition="'$(_IsCodeBrixUISolution)'==''" AssemblyFile="$(CodeBrixUIMSBuildTasksPath)\CodeBrix.Platform.UI.Tasks.v0.dll" TaskName="CodeBrix.Platform.UI.Tasks.RuntimeAssetsValidator.RuntimeAssetsValidatorTask_v0" Runtime="NET" TaskFactory="TaskHostFactory" />
	<UsingTask Condition="'$(_IsCodeBrixUISolution)'==''" AssemblyFile="$(CodeBrixUIMSBuildTasksPath)\CodeBrix.Platform.UI.Tasks.v0.dll" TaskName="CodeBrix.Platform.UI.Tasks.HotReloadInfo.HotReloadInfoTask_v0" Runtime="NET" TaskFactory="TaskHostFactory" />

	<UsingTask Condition="'$(_IsCodeBrixUISolution)'!=''" AssemblyFile="$(CodeBrixUIMSBuildTasksPath)\CodeBrix.Platform.UI.Tasks.v0.dll" TaskName="CodeBrix.Platform.UI.Tasks.ResourcesGenerator.ResourcesGenerationTask_v0" Runtime="NET" TaskFactory="TaskHostFactory"/>
	<UsingTask Condition="'$(_IsCodeBrixUISolution)'!=''" AssemblyFile="$(CodeBrixUIMSBuildTasksPath)\CodeBrix.Platform.UI.Tasks.v0.dll" TaskName="CodeBrix.Platform.UI.Tasks.ResourcesGenerator.UpriFeaturesGeneratorTask_v0" Runtime="NET" TaskFactory="TaskHostFactory"/>
	<UsingTask Condition="'$(_IsCodeBrixUISolution)'!=''" AssemblyFile="$(CodeBrixUIMSBuildTasksPath)\CodeBrix.Platform.UI.Tasks.v0.dll" TaskName="CodeBrix.Platform.UI.Tasks.ResourcesGenerator.UpriSubstitutionsGeneratorTask_v0" Runtime="NET" TaskFactory="TaskHostFactory" />
	<UsingTask Condition="'$(_IsCodeBrixUISolution)'!=''" AssemblyFile="$(CodeBrixUIMSBuildTasksPath)\CodeBrix.Platform.UI.Tasks.v0.dll" TaskName="CodeBrix.Platform.UI.Tasks.Assets.RetargetAssets_v0" Runtime="NET" TaskFactory="TaskHostFactory" />
	<UsingTask Condition="'$(_IsCodeBrixUISolution)'!=''" AssemblyFile="$(CodeBrixUIMSBuildTasksPath)\CodeBrix.Platform.UI.Tasks.v0.dll" TaskName="CodeBrix.Platform.UI.Tasks.RuntimeAssetsSelector.RuntimeAssetsSelectorTask_v0" Runtime="NET" TaskFactory="TaskHostFactory" />
	<UsingTask Condition="'$(_IsCodeBrixUISolution)'!=''" AssemblyFile="$(CodeBrixUIMSBuildTasksPath)\CodeBrix.Platform.UI.Tasks.v0.dll" TaskName="CodeBrix.Platform.UI.Tasks.RuntimeAssetsValidator.RuntimeAssetsValidatorTask_v0" Runtime="NET" TaskFactory="TaskHostFactory" />
	<UsingTask Condition="'$(_IsCodeBrixUISolution)'!=''" AssemblyFile="$(CodeBrixUIMSBuildTasksPath)\CodeBrix.Platform.UI.Tasks.v0.dll" TaskName="CodeBrix.Platform.UI.Tasks.HotReloadInfo.HotReloadInfoTask_v0" Runtime="NET" TaskFactory="TaskHostFactory" />

	<Target Name="_CodeBrixLangSetup">
		<!-- String resources -->
		<PropertyGroup>
			<!-- LEGACY: Old projects define DefaultApplicationLanguage instead of DefaultLanguage -->
			<DefaultLanguage Condition="'$(DefaultLanguage)'=='' and '$(DefaultApplicationLanguage)'!=''">$(DefaultApplicationLanguage)</DefaultLanguage>
			<!-- Default to English if DefaultLanguage isn't set -->
			<DefaultLanguage Condition="'$(DefaultLanguage)'==''">en</DefaultLanguage>
		</PropertyGroup>
	</Target>

	<PropertyGroup>
		<!--
		Ensures that AssignLinkMetadata runs before AssignTargetPaths.
		Otherwise, AssignTargetPath will generate a rooted path and will break embedded sources
		LogicalName metadata's behavior.
		-->
		<AssignTargetPathsDependsOn>$(AssignTargetPathsDependsOn);AssignLinkMetadata</AssignTargetPathsDependsOn>

		<_CodeBrixUnderlyingPlatform Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'android'">android</_CodeBrixUnderlyingPlatform>
		<_CodeBrixUnderlyingPlatform Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'ios' OR $([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'maccatalyst' OR $([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'tvos'">uikit</_CodeBrixUnderlyingPlatform>
		<_CodeBrixUnderlyingPlatform Condition="'$(CodeBrixRuntimeIdentifier)'=='WebAssembly'">wasm</_CodeBrixUnderlyingPlatform>
		<_CodeBrixUnderlyingPlatform Condition="'$(_CodeBrixUnderlyingPlatform)'=='' AND '$(CodeBrixRuntimeIdentifier)'=='Skia'">skia</_CodeBrixUnderlyingPlatform>
	</PropertyGroup>

	<!--
	  This task transforms all the Content files and PRIResources into resources files compatible for each platform.

	  Note: For Apple UIKit and Android, it must be run early in the build process, but no publicly stable target is available
	  to inject CodeBrix.Platform properly. Failing to add this task early enough makes X.A and X.I miss the generated resource files.
	-->
	<Target Name="CodeBrixResourcesGeneration"
				BeforeTargets="_GetLibraryImports;PrepareForBuild;_CheckForContent;_CollectBundleResources;_ComputeAndroidResourcePaths"
				DependsOnTargets="ResolveProjectReferences;_CodeBrixLangSetup"
				Condition="'$(DesignTimeBuild)' != 'true'">

		<CheckForDevenv Condition="'$(SolutionFileName)'=='CodeBrix.Platform.UI.slnx' and '$(MSBuildRuntimeType)'!='Core'" />

		<PropertyGroup>
			<!-- String resources -->
			<_CodeBrixUnderlyingPlatform Condition="'$(CodeBrixForceProcessPRIResource)'!=''"></_CodeBrixUnderlyingPlatform>

			<!-- Determine CodeBrixHead (with xamarin heads detection) -->
			<_IsCodeBrixHead>false</_IsCodeBrixHead>
			<_IsCodeBrixHead Condition="'$(IsCodeBrixHead)'=='true' or '$(AndroidApplication)'=='true' or '$(ProjectTypeGuids)'!=''">true</_IsCodeBrixHead>
		</PropertyGroup>

		<ItemGroup>
			<_CodeBrixTempPRIResource Include="@(PRIResource)" />
		</ItemGroup>

		<!-- Assign the Link property so files defined in shared projects preserve their natural path structure -->
		<AssignLinkMetadata Items="@(PRIResource)"
							Condition="'@(PRIResource)' != '' and '%(PRIResource.DefiningProjectFullPath)' != '$(MSBuildProjectFullPath)'">
			<Output TaskParameter="OutputItems" ItemName="_Temp" />
		</AssignLinkMetadata>

		<ItemGroup>
			<!-- remove new linked items so their new metadata is used instead -->
			<_CodeBrixTempPRIResource Remove="@(_Temp)" />
			<_CodeBrixTempPRIResource Include="@(_Temp)" />

			<!-- Clear temporary group -->
			<_Temp Remove="@(_Temp)" />
		</ItemGroup>

		<AssignTargetPath Files="@(_CodeBrixTempPRIResource)" RootFolder="$(MSBuildProjectDirectory)">
			<Output TaskParameter="AssignedFiles" ItemName="PRIResourceWithTargetPath" />
		</AssignTargetPath>

		<PropertyGroup>
			<_ResourceOutputPath>$(IntermediateOutputPath)g\ResourcesGenerator</_ResourceOutputPath>
			<_ResourceStampFile>$(IntermediateOutputPath)g\codebrix.stamp</_ResourceStampFile>
		</PropertyGroup>

		<ResourcesGenerationTask_v0 Resources="@(PRIResourceWithTargetPath)"
									 TargetProjectDirectory="$(ProjectDir)"
									 TargetPlatform="$(_CodeBrixUnderlyingPlatform)"
									 OutputPath="$(_ResourceOutputPath)"
									 DefaultLanguage="$(DefaultLanguage)"
									 IsCodeBrixHead="$(_IsCodeBrixHead)"
									 ProjectName="$(AssemblyName)"
									 EnableTraceLogging="$(CodeBrixResourcesGenerationEnableTraceLogging)">
			<Output TaskParameter="GeneratedFiles"
							ItemName="GeneratedFiles" />
		</ResourcesGenerationTask_v0>
		<ItemGroup>
			<BundleResource Condition="'%(GeneratedFiles.CodeBrixResourceTarget)' =='UIKit'" Include="@(GeneratedFiles)" />
			<_CodeBrixAndroidResources Condition="'%(GeneratedFiles.CodeBrixResourceTarget)' =='Android'" Include="@(GeneratedFiles)" />
			<LibraryResourceDirectories Condition="'@(_CodeBrixAndroidResources->Count ())' != '0' " Include="$(_ResourceOutputPath)\r">
				<StampFile>$(_ResourceStampFile)</StampFile>
			</LibraryResourceDirectories>
			<EmbeddedResource Condition="'%(GeneratedFiles.CodeBrixResourceTarget)' =='CodeBrix'" Include="@(GeneratedFiles)" />

			<!-- Clear temporary group -->
			<_CodeBrixTempPRIResource Remove="@(_CodeBrixTempPRIResource)" />

			<!-- Ensure files are tracked properly for incremental build and clean targets -->
			<FileWrites Include="@(GeneratedFiles)" />
		</ItemGroup>
	</Target>

	<Target Name="_CodeBrixExcludeFromAndroidContentCheck" BeforeTargets="_CheckForContent" Condition="'$(MonoAndroidAssetsPrefix)'!=''">
		<!--
		Disables "XA0101 build action is not supported" as CodeBrix.Platform handles Content items explicitly
		https://github.com/xamarin/xamarin-android/blob/311b41e864a0162895d079477cb9398fbec5ca6e/src/Xamarin.Android.Build.Tasks/Xamarin.Android.Common.targets#L833
		-->
		<ItemGroup>
			<Content Update="@(Content)" ExcludeFromContentCheck="true" />
		</ItemGroup>
	</Target>

	<!-- 
		The CodeBrixAssetsGeneration must be run at design time as well, as it 
		interacts with the `.R` generation on android. If not run, temporary
		resource files may be deleted incorrectly by design time builds.
	-->
	<Target Name="CodeBrixAssetsGeneration"
				BeforeTargets="_GetLibraryImports;_CheckForContent;_CollectBundleResources;_CompileAppManifest;_ComputeAndroidResourcePaths"
				DependsOnTargets="ResolveProjectReferences;GetCopyToOutputDirectoryItems;_CodeBrixLangSetup"
				Condition="
				'$(BuildingInsideCodeBrixSourceGenerator)' == ''
				and ('$(IsCodeBrixHead)'=='true'
					or '$(AndroidApplication)'=='true'
					or '$(ProjectTypeGuids)'!='')">
		<!-- Assets -->
		<PropertyGroup>
			<UseHighDPIResources Condition="'$(UseHighDPIResources)'==''">True</UseHighDPIResources>

			<_CodeBrixIosAppManifest>$(AppBundleManifest)</_CodeBrixIosAppManifest>

			<!-- Required for older Xamarin versions -->
			<_CodeBrixIosAppManifest Condition="'$(_CodeBrixIosAppManifest)'==''">$(_AppManifest)</_CodeBrixIosAppManifest>
		</PropertyGroup>

		<RetargetAssets_v0 UseHighDPIResources="$(UseHighDPIResources)"
							TargetPlatform="$(_CodeBrixUnderlyingPlatform)"
							DefaultLanguage="$(DefaultLanguage)"
							IntermediateOutputPath="$(IntermediateOutputPath)"
							ContentItems="@(ContentWithTargetPath);@(_SourceItemsToCopyToOutputDirectory)"
							AndroidAssetsPrefix="$(MonoAndroidAssetsPrefix)"
							IosAppManifest="$(_CodeBrixIosAppManifest)"
							Condition="'$(_CodeBrixUnderlyingPlatform)'!=''">
			<Output TaskParameter="Assets"
							ItemName="Assets" />
			<Output TaskParameter="RetargetedAssets"
							ItemName="RetargetedAssets" />
			<Output TaskParameter="PartialAppManifests"
							ItemName="PartialAppManifest" />
		</RetargetAssets_v0>
		<ItemGroup>
			<Content Remove="@(Assets)" />
		</ItemGroup>
		<ItemGroup Condition="'$(_CodeBrixUnderlyingPlatform)'=='uikit'">
			<BundleResource Condition="'%(RetargetedAssets.AssetType)' == 'image'" Include="@(RetargetedAssets)" />
			<BundleResource Condition="'%(RetargetedAssets.AssetType)' == 'generic'" Include="@(RetargetedAssets)" />

			<FileWrites Condition="'%(RetargetedAssets.AssetType)' == 'image'" Include="@(RetargetedAssets)" />
			<FileWrites Condition="'%(RetargetedAssets.AssetType)' == 'generic'" Include="@(RetargetedAssets)" />
		</ItemGroup>
		<ItemGroup Condition="'$(_CodeBrixUnderlyingPlatform)'=='android'">
			<AndroidResource Condition="'%(RetargetedAssets.AssetType)' =='image'" Include="@(RetargetedAssets)" />
			<AndroidAsset Condition="'%(RetargetedAssets.AssetType)' =='generic'" Include="@(RetargetedAssets)" />

			<!-- Ensure files are tracked properly for incremental build and clean targets -->
			<FileWrites Condition="'%(RetargetedAssets.AssetType)' =='image'" Include="@(RetargetedAssets)" />
			<FileWrites Condition="'%(RetargetedAssets.AssetType)' =='generic'" Include="@(RetargetedAssets)" />
		</ItemGroup>
	</Target>

	<!--
	  Upri Resources Trimming
	-->

	<Target Name="_CodeBrixLinkerUpriSubstitutions"
		Condition="'$(DesignTimeBuild)' != 'true'"
		AfterTargets="CodeBrixResourcesGeneration">

		<ItemGroup>
			<_CodeBrixUpriResource Condition="'%(GeneratedFiles.CodeBrixResourceTarget)' == 'CodeBrix'" Include="@(GeneratedFiles->'%(LogicalName)')">
				<Language>%(GeneratedFiles.Language)</Language>
			</_CodeBrixUpriResource>
		</ItemGroup>

		<PropertyGroup>
			<_CodeBrixUpriSubstitutionsFile>$(IntermediateOutputPath)\Substitutions\UpriResources.Substitutions.xml</_CodeBrixUpriSubstitutionsFile>
		</PropertyGroup>

		<UpriSubstitutionsGeneratorTask_v0
			AssemblyName="$(AssemblyName)"
			Resources="@(_CodeBrixUpriResource)"
			EnableXamlTrimmingIntegration="$(CodeBrixXamlResourcesUpriTrimming)"
			OutputFile="$(_CodeBrixUpriSubstitutionsFile)" />

		<ItemGroup>
			<FileWrites Include="$(_CodeBrixUpriSubstitutionsFile)" Condition="Exists('$(_CodeBrixUpriSubstitutionsFile)')" />
		</ItemGroup>

	</Target>

	<Target Name="_CodeBrixLinkerUpriFeatures"
		Condition="'$(IsCodeBrixHead)'=='true'"
		BeforeTargets="BuildDist;PrepareForILLink">

		<UpriFeaturesGeneratorTask_v0
			Languages="@(CodeBrixSupportedLanguage)">
			<Output TaskParameter="OutputFeatures" ItemName="_UpriOutputFeatures" />
		</UpriFeaturesGeneratorTask_v0>

		<ItemGroup>
			<RuntimeHostConfigurationOption Include="@(_UpriOutputFeatures)" Trim="true" />
		</ItemGroup>

	</Target>

	<!--
	  Linker Substitutions Merge
	  -->

	<Target Name="_CodeBrixLinkerCollectSubstitutions"
		Condition="'$(_CodeBrixRequiresEmbeddedResourcesInjection)' == 'true'"
		AfterTargets="CoreCompile">

		<ItemGroup>
			<_SubstitutionFiles Include="@(CodeBrixLinkerSubstitution)" />
			<_SubstitutionFiles Include="$(IntermediateOutputPath)\Substitutions\*.Substitutions.xml" />
		</ItemGroup>

	</Target>

	<Target Name="_CodeBrixLinkerSubstitutionsMerge"
		Condition="'$(_CodeBrixRequiresEmbeddedResourcesInjection)' == 'true' and @(_SubstitutionFiles->Count()) > 0 and '$(Configuration)' == 'Release'"
		BeforeTargets="_CodeBrixEmbeddedResourcesInjection">

		<LinkerDefinitionMergerTask_v0
			DefinitionFiles="@(_SubstitutionFiles)"
			TargetDefinitionFile="$(IntermediateOutputPath)ILLink.Substitutions.xml" />

		<ItemGroup>
			<_CodeBrixInjectedResource Include="$(IntermediateOutputPath)ILLink.Substitutions.xml" LogicalName="ILLink.Substitutions.xml" />

			<FileWrites Include="$(IntermediateOutputPath)ILLink.Substitutions.xml" />
		</ItemGroup>

	</Target>

	<PropertyGroup>
		<TargetsTriggeredByCompilation>$(TargetsTriggeredByCompilation);_CodeBrixSetupEmbeddedResourcesInjection</TargetsTriggeredByCompilation>
	</PropertyGroup>

	<Target Name="_CodeBrixSetupEmbeddedResourcesInjection">

		<PropertyGroup Condition="'$(DesignTimeBuild)' != 'true' and '$(SkipCompilerExecution)' == ''">
			<_CodeBrixRequiresEmbeddedResourcesInjection>true</_CodeBrixRequiresEmbeddedResourcesInjection>
		</PropertyGroup>

	</Target>

	<Target Name="_CodeBrixEmbeddedResourcesInjection"
		Condition="'$(_CodeBrixRequiresEmbeddedResourcesInjection)' == 'true'"
		AfterTargets="Compile;CompileTypeScriptWithTSConfig">

		<ItemGroup>
			<!-- Filter ReferenceCopyLocalPaths as it may contain pdbs as well -->
			<_CodeBrixEmbeddedResourcesInjectionAssembliesForReferencePaths Include="@(ReferencePath)" Condition="'%(Extension)' == '.dll'" />
		</ItemGroup>

		<EmbeddedResourceInjectorTask_v0
			EmbeddedResources="@(_CodeBrixInjectedResource)"
			TargetAssembly="$(IntermediateOutputPath)$(TargetFileName)"
			ReferencePath="@(_CodeBrixEmbeddedResourcesInjectionAssembliesForReferencePaths)" />

	</Target>

	<!--
	  XAML Resources Trimming
	  -->
	<PropertyGroup>
		<_CodeBrixLinkerHintsPass1DependsOnTargets>
			$(_CodeBrixLinkerHintsPass1DependsOnTargets);
			PrepareForILLink;
		</_CodeBrixLinkerHintsPass1DependsOnTargets>
		<_CodeBrixLinkerHintsPass1BeforeTargets>
			$(_CodeBrixLinkerHintsPass1BeforeTargets);
			BuildDist;
			_RunILLink;
		</_CodeBrixLinkerHintsPass1BeforeTargets>
	</PropertyGroup>
	

	<Target Name="_CodeBrixLinkerHintsPass1"
		  Condition="
			'$(IsCodeBrixHead)'=='true'
			and '$(CodeBrixXamlResourcesTrimming)'=='true'
			and $(_IsXamlTrimmingAvailable)"
		  DependsOnTargets="$(_CodeBrixLinkerHintsPass1DependsOnTargets)"
		  BeforeTargets="$(_CodeBrixLinkerHintsPass1BeforeTargets)">

		<Error Condition="'$(ILLinkTasksAssembly)'==''" Text="The property 'ILLinkTasksAssembly' wasn't set. You need to set _RequiresILLinkPack MSBuild property to true, or reference Microsoft.NET.ILLink.Tasks NuGet package with version same as your TargetFramework version." />

		<ItemGroup>
			<!-- Filter ReferenceCopyLocalPaths as it may contain pdbs as well -->
			<_CodeBrixLinkerHintsPass1AssembliesForReferencePaths
					Include="@(ManagedAssemblyToLink)"
					Condition="'%(Extension)' == '.dll'" />
		</ItemGroup>

		<PropertyGroup>
			<_CodeBrixUIPackageBasePath
				Condition="
					'%(CodeBrixRuntimeEnabledPackage.Identity)'=='CodeBrix.Platform.UI'
					or '%(CodeBrixRuntimeEnabledPackage.Identity)'=='CodeBrix.Platform.WinUI'"
				>%(CodeBrixRuntimeEnabledPackage.PackageBasePath)</_CodeBrixUIPackageBasePath>

			<!-- .NET 10 RC2+ path structure: tools/net/illink.dll -->
			<_CodeBrixLinkerHintGeneratorILLinkerPath Condition="'$(ILLinkTasksAssembly)'!=''">$([System.IO.Path]::Combine($([System.IO.Path]::GetDirectoryName($(ILLinkTasksAssembly))), '..', 'net'))</_CodeBrixLinkerHintGeneratorILLinkerPath>
			<!-- Pre-.NET 10 path structure: tools/net10.0/illink.dll -->
			<_CodeBrixLinkerHintGeneratorILLinkerPath_PreNet10 Condition="'$(ILLinkTasksAssembly)'!=''">$([System.IO.Path]::Combine($([System.IO.Path]::GetDirectoryName($(ILLinkTasksAssembly))), '..', 'net$(TargetFrameworkVersion.Substring(1))'))</_CodeBrixLinkerHintGeneratorILLinkerPath_PreNet10>
			
			<!-- Fall back to pre-.NET 10 path if .NET 10 RC2+ path doesn't exist -->
			<_CodeBrixLinkerHintGeneratorILLinkerPath Condition="'$(ILLinkTasksAssembly)'!='' and !Exists($([System.IO.Path]::Combine($(_CodeBrixLinkerHintGeneratorILLinkerPath), 'illink.dll')))">$(_CodeBrixLinkerHintGeneratorILLinkerPath_PreNet10)</_CodeBrixLinkerHintGeneratorILLinkerPath>
			
			<_CodeBrixLinkerHintsOutputPath>$([System.IO.Path]::Combine($([System.IO.Path]::GetFullPath('$(IntermediateOutputPath)')),'linkerhints'))</_CodeBrixLinkerHintsOutputPath>
		</PropertyGroup>

		<LinkerHintGeneratorTask_v0
			CurrentProjectPath="$(MSBuildProjectDirectory)"
			AssemblyPath="@(IntermediateAssembly)"
			OutputPath="$(_CodeBrixLinkerHintsOutputPath)"
			ReferencePath="@(_CodeBrixLinkerHintsPass1AssembliesForReferencePaths)"
			ILLinkerPath="$(_CodeBrixLinkerHintGeneratorILLinkerPath)"
			TrimmerRootDescriptor="@(TrimmerRootDescriptor)"
			TargetFramework="$(TargetFramework)"
			TargetFrameworkVersion="$(TargetFrameworkVersion.Substring(1))"
			CodeBrixUIPackageBasePath="$(_CodeBrixUIPackageBasePath)"
			CodeBrixRuntimeIdentifier="$(CodeBrixRuntimeIdentifier)">
			<Output TaskParameter="OutputFeatures"
					 ItemName="_LinkerHintOutputFeatures" />
		</LinkerHintGeneratorTask_v0>

		<ItemGroup>
			<!--
			 Align with latest https://github.com/dotnet/runtime/blob/dbb3f759798208ca7463059e0c87c0f45704b62f/src/tools/illink/src/ILLink.Tasks/build/Microsoft.NET.ILLink.targets#L303
			 We need to execute after PrepareForILLink but before _RunILLink which copies RuntimeHostConfigurationOption before we can edit it.
			-->
			<_TrimmerFeatureSettings Include="@(_LinkerHintOutputFeatures)" Trim="true" />
		</ItemGroup>
	</Target>

	<Target Name="_CodeBrixLinkerAndroidUITestSupport"
			Condition="'$(IsCodeBrixHead)'=='true' and '$(TargetPlatformIdentifier)'=='android' and '$(IsUiAutomationMappingEnabled)'!='true'"
			BeforeTargets="PrepareForILLink">

		<ItemGroup>
			<RuntimeHostConfigurationOption Include="AndroidUITestSupport" Value="false" Trim="true" />
		</ItemGroup>

		<PropertyGroup>
			<_ExtraTrimmerArgs>--link-attributes "$(MSBuildThisFileDirectory)Descriptors/Platform.UI.LinkAttributes.Android.xml" $(_ExtraTrimmerArgs)</_ExtraTrimmerArgs>
		</PropertyGroup>

	</Target>

	<!-- Warn when the task is executed in devenv.exe: https://github.com/dotnet/project-system/issues/4494 -->
	<UsingTask
		TaskName="CheckForDevenv"
		TaskFactory="CodeTaskFactory"
		AssemblyFile="$(MSBuildToolsPath)\Microsoft.Build.Tasks.Core.dll" >
		<ParameterGroup />
		<Task>
			<Reference Include="System.Xml"/>
			<Using Namespace="System"/>
			<Using Namespace="System.IO"/>
			<Code Type="Fragment" Language="cs">
				<![CDATA[  
            if (System.Diagnostics.Process.GetCurrentProcess().ProcessName.Equals("devenv", System.StringComparison.OrdinalIgnoreCase))
            {
              Log.LogWarning("The CodeBrix.Platform.UI.Tasks build task is running under devenv.exe you will have to restart Visual Studio to rebuild it.");
            }
          ]]>
			</Code>
		</Task>
	</UsingTask>

	<Target
		Name="_GenerateHotReloadInfo"
		BeforeTargets="BeforeCompile"
		Condition="'$(CodeBrixGenerateHotReloadInfo)' == 'True'">

		<HotReloadInfoTask_v0
			IntermediateOutputPath="$(IntermediateOutputPath)">
			<Output
				TaskParameter="GeneratedFiles"
				ItemName="_HotReloadInfoTaskGeneratedFiles" />
		</HotReloadInfoTask_v0>

		<ItemGroup>
			<Compile Include="@(_HotReloadInfoTaskGeneratedFiles)" />
		</ItemGroup>
	</Target>

</Project>
