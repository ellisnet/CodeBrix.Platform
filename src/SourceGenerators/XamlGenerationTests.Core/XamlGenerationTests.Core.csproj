<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<!-- There is no need to multi-target this test project -->
		<!-- We keep it on the oldest supported TFM -->
		<!-- Though we could use CodeBrixTargetFrameworkOverride to choose between NetPrevious and NetCurrent -->
		<!-- As of writing this comment, we don't see a need to do that, so we keep it simple -->
		<TargetFramework>$(NetCurrent)</TargetFramework>
	</PropertyGroup>

	<PropertyGroup>
		<DefaultLanguage>en-US</DefaultLanguage>
	</PropertyGroup>

	<Import Project="../../targetframework-override.props" />

	<ItemGroup>
		<ProjectReference Include="..\..\Platform.UI\Platform.UI.Reference.csproj" />
		<ProjectReference Include="..\..\Platform.UWP\Platform.Reference.csproj" />
		<ProjectReference Include="..\..\Platform.Foundation\Platform.Foundation.Reference.csproj" />
		<ProjectReference Include="..\..\Platform.UI.Toolkit\Platform.UI.Toolkit.Reference.csproj" />
	</ItemGroup>

	<Import Project="..\Platform.UI.SourceGenerators\Content\Platform.UI.SourceGenerators.props" />

</Project>
