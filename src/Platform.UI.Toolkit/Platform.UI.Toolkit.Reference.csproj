<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<TargetFrameworks>$(NetReferencePreviousAndCurrent)</TargetFrameworks>
	</PropertyGroup>

	<Import Project="../targetframework-override.props" />

	<PropertyGroup>
		<AssemblyName>CodeBrix.Platform.UI.Toolkit</AssemblyName>
		<RootNamespace>CodeBrix.Platform.UI.Toolkit</RootNamespace>
		<DefaultLanguage>en-US</DefaultLanguage>

		<ProduceReferenceAssembly>false</ProduceReferenceAssembly>
		<Deterministic>true</Deterministic>

		<UseCommonOverridePackage>true</UseCommonOverridePackage>
		<CommonOverridePackageId>CodeBrix.Platform.UI</CommonOverridePackageId>

		<CodeBrixRuntimeIdentifier>Reference</CodeBrixRuntimeIdentifier>
	</PropertyGroup>

  <ItemGroup>
    <Compile Include="..\..\src-platforms\Platform.Simple\SimpleCommand.cs" Link="Simple\SimpleCommand.cs" />
    <Compile Include="..\..\src-platforms\Platform.Simple\SimpleDialog.cs" Link="Simple\SimpleDialog.cs" />
    <Compile Include="..\..\src-platforms\Platform.Simple\SimpleEnum.cs" Link="Simple\SimpleEnum.cs" />
    <Compile Include="..\..\src-platforms\Platform.Simple\SimpleMessaging.cs" Link="Simple\SimpleMessaging.cs" />
    <Compile Include="..\..\src-platforms\Platform.Simple\SimpleOsInfo.cs" Link="Simple\SimpleOsInfo.cs" />
    <Compile Include="..\..\src-platforms\Platform.Simple\SimpleServiceResolver.cs" Link="Simple\SimpleServiceResolver.cs" />
    <Compile Include="..\..\src-platforms\Platform.Simple\SimpleViewModel.cs" Link="Simple\SimpleViewModel.cs" />
		<Compile Include="..\Platform.UI\Behaviors\VisibleBoundsPadding.cs" Link="VisibleBoundsPadding.cs" />
	</ItemGroup>

	<PropertyGroup>
		<CodeBrixUIMSBuildTasksPath>$(MSBuildThisFileDirectory)..\SourceGenerators\Platform.UI.Tasks\bin\$(Configuration)_Shadow</CodeBrixUIMSBuildTasksPath>
	</PropertyGroup>

	<Import Project="..\SourceGenerators\Platform.UI.Tasks\Content\Platform.UI.Tasks.targets" Condition="'$(SkipCodeBrixResourceGeneration)' == '' " />

	<ItemGroup>
		<ProjectReference Include="..\Platform.UI\Platform.UI.Reference.csproj">
			<Name>CodeBrix.Platform.UI</Name>
		</ProjectReference>
		<ProjectReference Include="..\Platform.UWP\Platform.Reference.csproj">
			<Name>Platform.UWP</Name>
		</ProjectReference>
		<ProjectReference Include="..\Platform.Foundation\Platform.Foundation.Reference.csproj">
			<Name>CodeBrix.Platform.Foundation</Name>
		</ProjectReference>
	</ItemGroup>

  <ItemGroup>
    <Folder Include="Simple\" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="10.0.9" />
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" Version="10.0.9" />
  </ItemGroup>

	<Import Project="..\SourceGenerators\Platform.UI.SourceGenerators\Content\Platform.UI.SourceGenerators.props" />

	<Target Name="_CodeBrixToolkitOverrideNuget" AfterTargets="AfterBuild" DependsOnTargets="BuiltProjectOutputGroup" Condition="'$(CodeBrixNugetOverrideVersion)'!=''">

		<PropertyGroup>
			<_OverrideTargetFramework>$(TargetFramework)</_OverrideTargetFramework>
			<_TargetNugetFolder>$(NuGetPackageRoot)\codebrix.platform.ui\$(CodeBrixNugetOverrideVersion)\lib\$(_OverrideTargetFramework)</_TargetNugetFolder>
		</PropertyGroup>
		<ItemGroup>
			<_OutputFiles Include="$(TargetDir)**" />
		</ItemGroup>
		<MakeDir Directories="$(_TargetNugetFolder)" />

		<Message Importance="high" Text="OVERRIDING NUGET PACKAGE CACHE: $(_TargetNugetFolder)" />

		<Copy SourceFiles="@(_OutputFiles)" DestinationFiles="@(_OutputFiles->'$(_TargetNugetFolder)\%(RecursiveDir)%(Filename)%(Extension)')" />
		<Copy SourceFiles="@(_OutputFilesPDB)" DestinationFiles="@(_OutputFilesPDB->'$(_TargetNugetFolder)\%(RecursiveDir)%(Filename).pdb')" />
	</Target>
</Project>
