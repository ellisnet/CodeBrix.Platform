<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<TargetFrameworks>$(NetUnitTests)</TargetFrameworks>
		<OutputType>Exe</OutputType>
		<IsPackable>false</IsPackable>
		<OutputPath>bin\$(Platform)\$(Configuration)</OutputPath>
		<UseCodeBrixXamlParser>true</UseCodeBrixXamlParser>
		<ImportFrameworkWinFXTargets>false</ImportFrameworkWinFXTargets>
		<CodeBrixForceHotReloadCodeGen>true</CodeBrixForceHotReloadCodeGen>
		<AssemblyName>CodeBrix.Platform.UI.Tests</AssemblyName>
		<RootNamespace>CodeBrix.Platform.UI.Tests</RootNamespace>
	</PropertyGroup>

	<Import Project="../targetframework-override.props" />

	<!--
	Uncomment to troubleshoot source generation
	<PropertyGroup>
		<CodeBrixUISourceGeneratorDebuggerBreak>True</CodeBrixUISourceGeneratorDebuggerBreak>
		<EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>
	</PropertyGroup>
	-->

	<ItemGroup Label="GlobalUsings">
		<Using Include="SilverAssertions" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.Extensions.Logging.Debug" />
		<PackageReference Include="Microsoft.Extensions.Logging.Console" />
		<PackageReference Include="MSTest" />
		<PackageReference Include="SilverAssertions.ApacheLicenseForever" Version="1.0.164.180" />
		<PackageReference Include="CodeBrix.TestMocks.ApacheLicenseForever" Version="1.0.165.1173" />

		<!-- https://github.com/NuGet/Home/issues/7344 -->
		<!--Hopefully we don't still need this-->
		<!--<PackageReference Include="System.Net.Http" Version="4.3.4" />-->

		<!-- https://github.com/NuGet/Home/issues/7344 -->
		<!--Hopefully we don't still need this-->
		<!--<PackageReference Include="System.Text.RegularExpressions" Version="4.3.1" />-->
	</ItemGroup>

	<ItemGroup>
		<Compile Include="$(MSBuildThisFileDirectory)..\CodeBrix.Platform.Net.Shared\Resources\**\*.cs">
			<Link>Resources\%(RecursiveDir)%(FileName)%(Extension)</Link>
		</Compile>
		<EmbeddedResource Include="$(MSBuildThisFileDirectory)..\CodeBrix.Platform.Net.Shared\Resources\**\*.resx">
			<Link>Resources\%(RecursiveDir)%(FileName)%(Extension)</Link>
		</EmbeddedResource>
	</ItemGroup>

	<PropertyGroup>
		<CodeBrixUIMSBuildTasksPath>$(MSBuildThisFileDirectory)..\SourceGenerators\Platform.UI.Tasks\bin\$(Configuration)_Shadow</CodeBrixUIMSBuildTasksPath>
		<CodeBrixForceProcessPRIResource>true</CodeBrixForceProcessPRIResource>
	</PropertyGroup>

	<Import Project="..\SourceGenerators\Platform.UI.SourceGenerators\Content\Platform.UI.SourceGenerators.props" />
	<Import Project="..\SourceGenerators\Platform.UI.Tasks\Content\Platform.UI.Tasks.targets" Condition="'$(SkipCodeBrixResourceGeneration)' == '' " />

	<ItemGroup>
		<EmbeddedResource Include="Windows_UI_Xaml_Markup\XamlReaderTests\*.xamltest" />
	</ItemGroup>
	<ItemGroup>
		<EmbeddedResource Include="Lottie\animation.json" />
		<EmbeddedResource Include="Windows_Data_Xml\DomTests\basictest.xml" />
		<EmbeddedResource Include="Windows_UI_XAML_Controls\UserControlTests\UserControl_WriteOnlyProperty_UserControl.xaml">
			<Generator>MSBuild:UpdateDesignTimeXaml</Generator>
		</EmbeddedResource>
	</ItemGroup>

	<ItemGroup>
		<PRIResource Include="**\*.resw" />
	</ItemGroup>
	<!-- CodeBrix.Platform fork: SamplesApp Page and Uno.UI.RemoteControl.VS Compile includes removed (both folders dropped). -->
	<ItemGroup>
		<Compile Include="..\Platform.UI.RuntimeTests\Helpers\SizeAssertion.cs" Link="Extensions\SizeAssertion.cs" />
		<Compile Include="..\Platform.UI.RuntimeTests\Tests\Windows_UI_Xaml_Controls\Given_ListViewBase_Items.cs" Link="Windows_UI_XAML_Controls\ListViewBaseTests\Given_ListViewBase_Items.cs" />
		<Compile Include="..\Platform.UI.RuntimeTests\Tests\Windows_UI_Xaml_Controls\GroupingObservableCollection.cs" Link="Windows_UI_XAML_Controls\ListViewBaseTests\GroupingObservableCollection.cs" />
		<Compile Include="..\SourceGenerators\Platform.UI.Tasks\ResourceConverters\AndroidResourceConverter.cs">
			<Link>Resources\AndroidResourceConverter.cs</Link>
		</Compile>
		<Compile Include="..\SourceGenerators\Platform.UI.Tasks\ResourceConverters\iOSResourceConverter.cs">
			<Link>Resources\iOSResourceConverter.cs</Link>
		</Compile>
	</ItemGroup>
	<ItemGroup>
		<ProjectReference Include="..\AddIns\Platform.UI.Lottie\Platform.UI.Lottie.Tests.csproj" />
		<ProjectReference Include="..\SourceGenerators\System.Xaml\Platform.Xaml.csproj" />
		<ProjectReference Include="..\Platform.UI.Adapter.Microsoft.Extensions.Logging\Platform.UI.Adapter.Microsoft.Extensions.Logging.csproj" />
		<ProjectReference Include="..\Platform.UI.FluentTheme\Platform.UI.FluentTheme.Tests.csproj" />
		<ProjectReference Include="..\Platform.UI.Tests.ViewLibrary\Platform.UI.Tests.ViewLibrary.csproj" />
		<ProjectReference Include="..\Platform.UI.Tests.ViewLibraryProps\Platform.UI.Tests.ViewLibraryProps.csproj" />
		<ProjectReference Include="..\Platform.UI\Platform.UI.Tests.csproj" />
		<ProjectReference Include="..\Platform.UI.Toolkit\Platform.UI.Toolkit.Tests.csproj" />
	</ItemGroup>

	<ItemGroup>
		<Service Include="{82a7f48d-3b50-4b1e-b82e-3ada8210c358}" />
	</ItemGroup>

	<ItemGroup>
		<Compile Update="ResourceLoader\Strings\en\Resources.Designer.cs">
			<DesignTime>True</DesignTime>
			<AutoGen>True</AutoGen>
			<DependentUpon>Resources.resw</DependentUpon>
		</Compile>
		<Compile Update="ResourceLoader\Strings\fr\Resources.Designer.cs">
			<DesignTime>True</DesignTime>
			<AutoGen>True</AutoGen>
			<DependentUpon>Resources.resw</DependentUpon>
		</Compile>
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\SourceGenerators\Platform.UI.SourceGenerators\Platform.UI.SourceGenerators.csproj">
			<ReferenceOutputAssembly>false</ReferenceOutputAssembly>
			<OutputItemType>Analyzer</OutputItemType>
		</ProjectReference>
		<ProjectReference Include="..\SourceGenerators\Platform.UI.SourceGenerators.Internal\Platform.UI.SourceGenerators.Internal.csproj">
			<ReferenceOutputAssembly>false</ReferenceOutputAssembly>
			<OutputItemType>Analyzer</OutputItemType>
		</ProjectReference>
		<ProjectReference Include="..\SourceGenerators\Platform.UI.Tasks\Platform.UI.Tasks.csproj">
			<ReferenceOutputAssembly>false</ReferenceOutputAssembly>
			<SkipGetTargetFrameworkProperties>true</SkipGetTargetFrameworkProperties>
			<UndefineProperties>TargetFramework</UndefineProperties>
		</ProjectReference>
	</ItemGroup>

	<ItemGroup>
		<UpToDateCheckInput Include="**\*.xaml" Exclude="bin\**\*.xaml;obj\**\*.xaml" />
	</ItemGroup>
	<ItemGroup>
		<None Update="ResourceLoader\Controls\When_Collection_And_InlineProperty.xaml">
			<Generator>MSBuild:Compile</Generator>
		</None>
		<None Update="ResourceLoader\Strings\en\Resources.resw">
			<Generator>ResXFileCodeGenerator</Generator>
			<LastGenOutput>Resources.Designer.cs</LastGenOutput>
		</None>
		<None Update="ResourceLoader\Strings\fr\Resources.resw">
			<LastGenOutput>Resources.Designer.cs</LastGenOutput>
			<Generator>ResXFileCodeGenerator</Generator>
		</None>
		<None Update="Windows_UI_XAML_Controls\UserControlTests\UserControl_WriteOnlyProperty.xaml">
			<Generator>MSBuild:Compile</Generator>
		</None>
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="../CodeBrix.Platform.Extensions.Logging/CodeBrix.Platform.Extensions.Logging.csproj" />
	</ItemGroup>
</Project>
