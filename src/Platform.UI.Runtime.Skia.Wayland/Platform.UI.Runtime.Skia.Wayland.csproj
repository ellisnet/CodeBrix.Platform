<Project Sdk="Microsoft.NET.Sdk">
	<!-- Identity pinned to legacy names; matches the family convention (see the X11 head). -->
	<PropertyGroup>
		<AssemblyName>CodeBrix.Platform.UI.Runtime.Skia.Wayland</AssemblyName>
	</PropertyGroup>

	<PropertyGroup>
		<TargetFrameworks>$(NetSkiaPreviousAndCurrent)</TargetFrameworks>
		<Nullable>enable</Nullable>
		<AllowUnsafeBlocks>true</AllowUnsafeBlocks>
	</PropertyGroup>

	<Import Project="../targetframework-override-noplatform.props" />

	<PropertyGroup>
		<!-- Packed by build/CodeBrix.Platform.Build.csproj with the shared date-stamped version. -->
		<GeneratePackageOnBuild>false</GeneratePackageOnBuild>
		<Title>CodeBrix.Platform.Runtime.Skia.Wayland</Title>
		<Description>Native Wayland Skia runtime host for CodeBrix.Platform applications (requires a Wayland compositor).</Description>

		<PackageId Condition="'$(CODEBRIX_UWP_BUILD)'!='true'">CodeBrix.Platform.Runtime.Skia.Wayland.ApacheLicenseForever</PackageId>

		<RootNamespace>CodeBrix.Platform.UI.Runtime.Skia.Wayland</RootNamespace>

		<UseCommonOverridePackage>true</UseCommonOverridePackage>
	</PropertyGroup>

	<ItemGroup>
		<None Include="..\..\icon-codebrix-128.png" Pack="true" PackagePath="\" Visible="false" />
		<None Include="..\..\README.md" Pack="true" PackagePath="\" Visible="false" />
		<None Include="..\..\AGENT-README.txt" Pack="true" PackagePath="\" Visible="false" />
		<None Include="..\..\THIRD-PARTY-NOTICES.txt" Pack="true" PackagePath="\" Visible="false" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="CodeBrix.Platform.LinuxDBus.MitLicenseForever" Version="1.0.165.1241" />
	</ItemGroup>

	<!-- NO CodeBrix.Platform.MediaPlayerCore (LGPL) here: the core Wayland head stays
	     permissive top to bottom. Media playback, if ever wanted, becomes a separate
	     LGPL-suffixed add-on package — never folded into this head. -->
	<ItemGroup>
		<PackageReference Include="SkiaSharp.NativeAssets.Linux" />
		<PackageReference Include="HarfBuzzSharp.NativeAssets.Linux" />
		<PackageReference Include="HarfbuzzSharp" />
		<PackageReference Include="SkiaSharp" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\Platform.UI.Runtime.Skia\Platform.UI.Runtime.Skia.csproj" />
		<ProjectReference Include="..\Platform.Foundation\Platform.Foundation.Skia.csproj" TreatAsPackageReference="false" PrivateAssets="all" />
		<ProjectReference Include="..\Platform.UI\Platform.UI.Skia.csproj" />
		<ProjectReference Include="..\Platform.UWP\Platform.Skia.csproj" TreatAsPackageReference="false" PrivateAssets="all" />
	</ItemGroup>

	<ItemGroup>
		<!-- Pack the buildTransitive props/targets renamed to <PackageId>.props/.targets so
		     NuGet auto-imports them for consumers (and to satisfy NU5129). -->
		<Content Include="buildTransitive\Platform.WinUI.Runtime.Skia.Wayland.props">
			<Pack>true</Pack>
			<PackagePath>buildTransitive\CodeBrix.Platform.Runtime.Skia.Wayland.ApacheLicenseForever.props</PackagePath>
		</Content>
		<Content Include="buildTransitive\Platform.WinUI.Runtime.Skia.Wayland.targets">
			<Pack>true</Pack>
			<PackagePath>buildTransitive\CodeBrix.Platform.Runtime.Skia.Wayland.ApacheLicenseForever.targets</PackagePath>
		</Content>
	</ItemGroup>
</Project>
