<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
	<PropertyGroup>
		<IsCodeBrixHead Condition="'$(OutputType)'=='Exe' OR '$(OutputType)'=='WinExe'">true</IsCodeBrixHead>
	</PropertyGroup>

	<Target Name="_CodeBrixSkiaWaylandFeatureDefines" AfterTargets="PrepareForBuild">
		<PropertyGroup>
			<DefineConstants>$(DefineConstants);CODEBRIX_REFERENCE_API;HAS_CODEBRIX_SKIA;HAS_CODEBRIX_SKIA_WAYLAND;__DESKTOP__;__CODEBRIX_SKIA__;__CODEBRIX_SKIA_WAYLAND__</DefineConstants>
		</PropertyGroup>
	</Target>

	<Target Name="_CodeBrixBeforeCopyLocal" BeforeTargets="CopyFilesToOutputDirectory;_CopyFilesMarkedCopyLocal">
		<ItemGroup>
			<ContentWithTargetPath Update="@(ContentWithTargetPath)" CopyToOutputDirectory="Always" />
		</ItemGroup>
	</Target>
</Project>
