<Project Sdk="Microsoft.NET.Sdk">
	<!-- Identity pinned to legacy names; rename step changed only the .csproj filename. -->
	<PropertyGroup>
		<AssemblyName>CodeBrix.Platform.UI.Runtime.Skia</AssemblyName>
	</PropertyGroup>


	<PropertyGroup>
		<TargetFrameworks>$(NetSkiaPreviousAndCurrent)</TargetFrameworks>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
	</PropertyGroup>

	<PropertyGroup>
		<!-- Packed by build/CodeBrix.Platform.Build.csproj with the shared date-stamped
		     version (GeneratePackageOnBuild off so it isn't packed with a stray version). -->
		<GeneratePackageOnBuild>false</GeneratePackageOnBuild>
		<Title>CodeBrix.Platform.Runtime.Skia</Title>
		<Description>Skia platform support for CodeBrix.Platform applications.</Description>

		<PackageId Condition="'$(CODEBRIX_UWP_BUILD)'!='true'">CodeBrix.Platform.Runtime.Skia.ApacheLicenseForever</PackageId>

		<RootNamespace>CodeBrix.Platform.UI.Runtime.Skia</RootNamespace>

		<UseCommonOverridePackage>true</UseCommonOverridePackage>
	</PropertyGroup>

	<ItemGroup>
		<None Include="..\..\icon-codebrix-128.png" Pack="true" PackagePath="\" Visible="false" />
		<None Include="..\..\README.md" Pack="true" PackagePath="\" Visible="false" />
		<None Include="..\..\AGENT-README.txt" Pack="true" PackagePath="\" Visible="false" />
		<None Include="..\..\THIRD-PARTY-NOTICES.txt" Pack="true" PackagePath="\" Visible="false" />
	</ItemGroup>

	<Import Project="../targetframework-override.props" />
	
	<ItemGroup>
		<ProjectReference Include="..\Platform.Foundation\Platform.Foundation.Skia.csproj" TreatAsPackageReference="false" PrivateAssets="all" />
		<ProjectReference Include="..\Platform.UI\Platform.UI.Skia.csproj" />
		<ProjectReference Include="..\Platform.UWP\Platform.Skia.csproj" TreatAsPackageReference="false" PrivateAssets="all" />
	</ItemGroup>

</Project>
